<Page
    x:Class="ArasToolkit.App.WinUI.Views.SettingsMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <TextBlock Text="设置" FontSize="24" FontWeight="Bold"
                       Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <TextBlock Text="应用配置与系统管理" FontSize="13"
                       Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,0,0,24" />

            <GridView x:Name="SettingsGrid"
                      IsItemClickEnabled="True"
                      SelectionMode="None"
                      ItemClick="SettingsGrid_ItemClick">
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="0,0,14,14" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="260" Padding="20,18"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{ThemeResource CardCornerRadius}">
                            <StackPanel>
                                <TextBlock Text="{Binding Icon}" FontSize="28" Margin="0,0,0,10"
                                           Foreground="{ThemeResource AccentBrush}" />
                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding Description}" FontSize="12"
                                           Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

        </StackPanel>
    </ScrollViewer>
</Page>
