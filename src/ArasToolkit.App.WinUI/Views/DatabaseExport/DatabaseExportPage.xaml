<Page
    x:Class="ArasToolkit.App.WinUI.Views.DatabaseExportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="32,28" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="📤 数据库导出" FontSize="26" FontWeight="Bold"
                       Foreground="{ThemeResource TextPrimaryBrush}" />
            <TextBlock Text="执行SQL查询并将结果导出为Excel文件" FontSize="14"
                       Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- 操作栏 -->
        <Border Grid.Row="1" Style="{ThemeResource CardStyle}" Padding="16,12">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="模板:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                              Style="{ThemeResource DarkComboBox}" Width="180">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TemplateName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="加载" Command="{Binding UseTemplateCommand}" Style="{ThemeResource PrimaryButton}" Height="32" Padding="10,0" />
                    <Button Content="删除" Command="{Binding DeleteTemplateCommand}" Style="{ThemeResource PrimaryButton}" Height="32" Padding="10,0" />
                    <TextBlock Text="存为:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="16,0,0,0" />
                    <TextBox Text="{Binding NewTemplateName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{ThemeResource DarkTextBox}" Width="120" Height="32" />
                    <Button Content="保存" Command="{Binding SaveTemplateCommand}" Style="{ThemeResource PrimaryButton}" Height="32" Padding="10,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="模式:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding ExportModeOptions}" SelectedItem="{Binding SelectedExportMode, Mode=TwoWay}"
                              Style="{ThemeResource DarkComboBox}" Width="120" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{Binding IsBatchMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="每批:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBox Text="{Binding BatchSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{ThemeResource DarkTextBox}" Width="70" Height="32" TextAlignment="Center" />
                        <TextBlock Text="条" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Content="▶ 执行导出" Command="{Binding ExecuteExportCommand}" Height="32" Padding="20,0"
                            Style="{ThemeResource AccentButton}"
                            Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- SQL编辑区 -->
        <Border Grid.Row="2" Style="{ThemeResource CardStyle}" Padding="16,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="SQL查询语句" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                    <TextBlock Text="（列的 AS 别名将作为 Excel 表头）" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
                <TextBox Text="{Binding SqlQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                         FontFamily="Consolas" FontSize="13" Padding="12,10"
                         Style="{ThemeResource DarkTextBox}" />
                <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap">
                    <Run Text="目标数据库: " /><Run Text="{Binding ConnectionString}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 进度区 -->
        <StackPanel Grid.Row="3" Spacing="4" Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibility}}">
            <Border Padding="12,10" CornerRadius="8" Background="#F0FDF4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ProgressText}" FontSize="13" Foreground="#166534" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="22,2,0,0">
                            <TextBlock Text="进度: " FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding ProgressPercentage, Converter={StaticResource StringFormat}, ConverterParameter='{}{0:F1}'}" FontSize="12" Foreground="#16A34A" FontWeight="Bold" />
                            <TextBlock Text="%" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕ 取消导出" Command="{Binding CancelExportCommand}"
                            Height="30" Padding="12,0" Style="{ThemeResource PrimaryButton}" VerticalAlignment="Center" />
                </Grid>
            </Border>
            <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                         Value="{Binding ProgressPercentage, Mode=OneWay}" Minimum="0" Maximum="100" Height="4" />
        </StackPanel>

        <!-- 状态/错误 -->
        <StackPanel Grid.Row="4" Spacing="6">
            <Border Background="#3FEF4444" CornerRadius="4" Padding="10,6"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" />
            </Border>
            <Border Background="#F0F9FF" CornerRadius="4" Padding="10,6"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1E40AF" FontSize="12" TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <!-- 导出结果 -->
        <Border Grid.Row="5" Style="{ThemeResource CardStyle}" Padding="16,12"
                Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" Text="📊 导出结果" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="总行: " FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding LastResult.TotalRows}" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}" />
                    <TextBlock Text="  导出: " FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding LastResult.ExportedRows}" FontSize="13" FontWeight="Bold" Foreground="#16A34A" />
                    <TextBlock Text=" 行  文件: " FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding LastResult.BatchCount}" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}" />
                    <TextBlock Text=" 个" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                </StackPanel>
                <Button Content="📄 查看导出日志" Click="OpenLogFile_Click" Tag="{Binding LastResult.LogFilePath}"
                        Margin="0,10,0,0" Padding="10,6" FontSize="12"
                        Background="Transparent" Foreground="#6366F1"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" />
            </StackPanel>
        </Border>

        <!-- 导出历史 -->
        <Border Grid.Row="6" Style="{ThemeResource SimpleCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,11">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="📜 导出历史" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <Button Content="🔄 刷新" Command="{Binding RefreshHistoryCommand}" Height="26" FontSize="11" Padding="10,0"
                                Style="{ThemeResource PrimaryButton}" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 表头 -->
                    <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,11">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="65" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="状态" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="1" Text="导出时间" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="2" Text="模式" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="3" Text="行数" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="4" Text="文件名" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="5" Text="操作" Style="{ThemeResource TableHeaderText}" />
                        </Grid>
                    </Border>

                    <!-- 表体 -->
                    <ListView Grid.Row="1" ItemsSource="{Binding HistoryRecords}"
                              Style="{ThemeResource TableListView}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,11" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="65" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StatusText}" Style="{ThemeResource TableCellText}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayExportTime}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ExportMode}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="3" Text="{Binding TotalRows}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="4" Text="{Binding FileName}" Style="{ThemeResource TableCellText}" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4">
                                            <Button Content="打开" Click="OpenFileButton_Click" Tag="{Binding}"
                                                    Padding="8,4" FontSize="11" Background="Transparent"
                                                    Foreground="{ThemeResource AccentBrush}" BorderThickness="0" />
                                            <Button Content="文件夹" Click="OpenFolderButton_Click" Tag="{Binding}"
                                                    Padding="8,4" FontSize="11" Background="Transparent"
                                                    Foreground="#6366F1" BorderThickness="0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Border>

        <!-- 分页栏 -->
        <Border Grid.Row="7" Style="{ThemeResource CardStyle}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding PageInfo}" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Content="◀ 上一页" Command="{Binding PrevPageCommand}" Style="{ThemeResource PagingButton}" Width="80" />
                    <Button Content="下一页 ▶" Command="{Binding NextPageCommand}" Style="{ThemeResource PagingButton}" Width="80" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
