<Page
    x:Class="ArasToolkit.App.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <!-- 页面标题 -->
            <TextBlock Text="仪表盘" FontSize="24" FontWeight="Bold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
            <TextBlock Text="Aras 开发工具箱" FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,24" />

            <!-- Aras链接详情 -->
            <TextBlock Text="Aras链接详情" FontSize="15" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,12" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                <Border Style="{ThemeResource ElevatedCard}" Width="210" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                     Fill="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusToBrush}}" />
                            <TextBlock Text="{Binding ConnectionStatus}" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                        <TextBlock Text="连接状态" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{ThemeResource SimpleCard}" Width="210" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ConnectedServer}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="服务器" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{ThemeResource SimpleCard}" Width="210" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ConnectedDatabase}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="数据库" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{ThemeResource SimpleCard}" Width="210" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ConnectedUser}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Aras用户" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Users链接详情 -->
            <TextBlock Text="Users链接详情" FontSize="15" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,12" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                <Border Style="{ThemeResource SimpleCard}" Width="210" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{Binding AppUsername}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="当前登录用户" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{ThemeResource SimpleCard}" Width="210" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{Binding AppDisplayName}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="显示名称" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{ThemeResource SimpleCard}" Width="210" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{Binding LoginTime}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Aras登录时间" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 全部功能入口 -->
            <TextBlock Text="全部功能" FontSize="16" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,16" />

            <GridView ItemsSource="{Binding AllFeatures}"
                      IsItemClickEnabled="True"
                      SelectionMode="None"
                      ItemClick="FeatureGrid_ItemClick">
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="0,0,14,14" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="260" Padding="20,18"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{ThemeResource CardCornerRadius}">
                            <StackPanel>
                                <TextBlock Text="{Binding Icon}" FontSize="28" Margin="0,0,0,10"
                                           Foreground="{ThemeResource SystemAccentBrush}" />
                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding Description}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

        </StackPanel>
    </ScrollViewer>
</Page>
