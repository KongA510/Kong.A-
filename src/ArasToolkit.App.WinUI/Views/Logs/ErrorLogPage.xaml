<Page
    x:Class="ArasToolkit.App.WinUI.Views.ErrorLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="32,28" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="错误日志" FontSize="26" FontWeight="Bold"
                           Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock Text="系统错误记录与排查" FontSize="14"
                           Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshCommand}"
                    Style="{ThemeResource PrimaryButton}" Height="36" VerticalAlignment="Bottom" />
        </Grid>

        <!-- 筛选栏 -->
        <Border Grid.Row="1" Style="{ThemeResource CardStyle}" Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="级别:" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13" />
                <ComboBox ItemsSource="{Binding FilterLevels}" SelectedItem="{Binding FilterLevel, Mode=TwoWay}"
                          Style="{ThemeResource DarkComboBox}" Width="120" />
                <TextBlock Text="从:" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13" />
                <DatePicker SelectedDate="{Binding FilterFromDate, Mode=TwoWay}" Width="180" />
                <TextBlock Text="到:" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13" />
                <DatePicker SelectedDate="{Binding FilterToDate, Mode=TwoWay}" Width="180" />
                <Button Content="筛选" Command="{Binding ApplyFilterCommand}"
                        Style="{ThemeResource PrimaryButton}" Height="34" Padding="16,6" />
                <Button Content="清空日志" Command="{Binding ClearCommand}"
                        Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0"
                        Height="34" Padding="16,6" CornerRadius="{ThemeResource AppControlCornerRadius}" />
            </StackPanel>
        </Border>

        <!-- 日志表格 -->
        <Border Grid.Row="2" Style="{ThemeResource SimpleCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 表头 -->
                <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,11">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="16" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="调用功能" Style="{ThemeResource TableHeaderText}" />
                        <TextBlock Grid.Column="1" Text="错误信息" Style="{ThemeResource TableHeaderText}" />
                        <TextBlock Grid.Column="2" Text="记录日期" Style="{ThemeResource TableHeaderText}" />
                        <TextBlock Grid.Column="3" Text="级别" Style="{ThemeResource TableHeaderText}" />
                    </Grid>
                </Border>

                <!-- 表体 -->
                <ListView Grid.Row="1" ItemsSource="{Binding Entries}"
                          Style="{ThemeResource TableListView}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16,11" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding FunctionName}" Style="{ThemeResource TableCellText}" />
                                    <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Style="{ThemeResource TableCellText}" />
                                    <TextBlock Grid.Column="2" Text="{Binding DisplayDate}" Style="{ThemeResource TableCellText}" />
                                    <TextBlock Grid.Column="3" Text="{Binding Level}" Style="{ThemeResource TableCellText}"
                                               Foreground="{Binding Level, Converter={StaticResource ErrorLevelToBrush}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- 分页栏 -->
        <Border Grid.Row="3" Style="{ThemeResource CardStyle}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding PageInfo}" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Content="⏮" Command="{Binding FirstPageCommand}" Style="{ThemeResource PagingButton}" />
                    <Button Content="◀" Command="{Binding PrevPageCommand}" Style="{ThemeResource PagingButton}" />
                    <Button Content="▶" Command="{Binding NextPageCommand}" Style="{ThemeResource PagingButton}" />
                    <Button Content="⏭" Command="{Binding LastPageCommand}" Style="{ThemeResource PagingButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
