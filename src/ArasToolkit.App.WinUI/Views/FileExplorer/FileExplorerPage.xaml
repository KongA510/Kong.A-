<Page
    x:Class="ArasToolkit.App.WinUI.Views.FileExplorerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="📁 我的资料" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}" />
            <TextBlock Text="文件资源管理器" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- 工具栏 -->
        <Border Grid.Row="1" Style="{ThemeResource CardStyle}" Padding="12,10">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="⬅ 返回" Command="{Binding NavigateBackCommand}"
                        Style="{ThemeResource PagingButton}" Width="70" />
                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" Padding="10,5" VerticalAlignment="Center">
                    <TextBlock Text="{Binding BreadcrumbPath}" FontSize="12"
                               Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                </Border>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                    <Button Content="📤 上传" Command="{Binding UploadFileCommand}"
                            Style="{ThemeResource PrimaryButton}" Height="32" FontSize="12" Padding="10,0" />
                    <Button Content="🔄" Command="{Binding RefreshCommand}"
                            Style="{ThemeResource PrimaryButton}" Width="32" Height="32" FontSize="14" />
                    <Button Content="📂" Command="{Binding BrowseFolderCommand}"
                            Style="{ThemeResource PrimaryButton}" Width="32" Height="32" FontSize="14" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 搜索栏 -->
        <Border Grid.Row="2" Style="{ThemeResource CardStyle}" Padding="12,8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🔍" FontSize="16" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="搜索文件..." FontSize="13" Style="{ThemeResource DarkTextBox}" />
            </Grid>
        </Border>

        <!-- 文件列表 -->
        <Border Grid.Row="3" Style="{ThemeResource SimpleCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 列标题 -->
                <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="16" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="名称" Style="{ThemeResource TableHeaderText}" />
                        <TextBlock Grid.Column="2" Text="大小" Style="{ThemeResource TableHeaderText}" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="修改时间" Style="{ThemeResource TableHeaderText}" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="操作" Style="{ThemeResource TableHeaderText}" HorizontalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- 文件项 -->
                <ListView Grid.Row="1" ItemsSource="{Binding CurrentItems}"
                          Style="{ThemeResource TableListView}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,5" Tag="{Binding}" DoubleTapped="Item_DoubleTapped"
                                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Background="{Binding IconColor, Converter={StaticResource StringToColorBrush}}">
                                        <TextBlock Text="{Binding Icon}" FontSize="15"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" Style="{ThemeResource TableCellText}"
                                               TextTrimming="CharacterEllipsis" Margin="4,0,0,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" FontSize="12" Style="{ThemeResource TableCellText}"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="3" Text="{Binding LastModifiedDisplay}" FontSize="12" Style="{ThemeResource TableCellText}"
                                               HorizontalAlignment="Right" />
                                    <Button Grid.Column="4" Content="📂" Click="OpenInExplorerButton_Click" Tag="{Binding}"
                                            HorizontalAlignment="Center" Padding="6,3" FontSize="12"
                                            Background="Transparent" BorderThickness="0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

                <TextBlock x:Name="EmptyLabel" Grid.Row="1" Text="此文件夹为空" FontSize="14"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <Border Grid.Row="4" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
        </Border>
    </Grid>
</Page>
