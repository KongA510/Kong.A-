<Page
    x:Class="ArasToolkit.App.WinUI.Views.PropertyTranslationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="🏷️ 属性翻译" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <TextBlock Text="Aras 对象类属性批量翻译工具" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,0,0,20" />

            <Border Style="{ThemeResource SimpleCard}" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="查询设置" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <TextBlock Text="查询模式:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding QueryModes}" SelectedItem="{Binding SelectedQueryMode, Mode=TwoWay}" Style="{ThemeResource DarkComboBox}" Width="130" />
                        <TextBlock Text="对象类:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <ComboBox ItemsSource="{Binding ItemTypeList}" SelectedItem="{Binding SelectedItemType, Mode=TwoWay}" Style="{ThemeResource DarkComboBox}" MinWidth="200">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="🔄 加载对象类" Command="{Binding LoadItemTypesCommand}" Style="{ThemeResource PrimaryButton}" Padding="14,5" />
                    </StackPanel>
                    <Button Content="📋 加载属性" Command="{Binding LoadPropertiesCommand}" Style="{ThemeResource PrimaryButton}" Padding="16,6" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Style="{ThemeResource SimpleCard}" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="属性列表" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                        <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"
                                   Text="{Binding PropertyList.Count, Converter={StaticResource StringFormat}, ConverterParameter='共 {0} 个属性'}" />
                    </Grid>
                    <Border Style="{ThemeResource SimpleCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,9">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="16" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="属性名称" Style="{ThemeResource TableHeaderText}" />
                                <TextBlock Grid.Column="1" Text="标签" Style="{ThemeResource TableHeaderText}" />
                                <TextBlock Grid.Column="2" Text="数据类型" Style="{ThemeResource TableHeaderText}" />
                                <TextBlock Grid.Column="3" Text="所属对象类" Style="{ThemeResource TableHeaderText}" />
                            </Grid>
                        </Border>
                        <ListView Grid.Row="1" ItemsSource="{Binding PropertyList}" Style="{ThemeResource TableListView}" ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="320">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,9" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{ThemeResource TableCellText}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" Style="{ThemeResource TableCellText}" />
                                            <TextBlock Grid.Column="2" Text="{Binding DataType}" Style="{ThemeResource TableCellText}" />
                                            <TextBlock Grid.Column="3" Text="{Binding ItemTypeName}" Style="{ThemeResource TableCellText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
</Border>
                </StackPanel>
            </Border>

            <Border Style="{ThemeResource SimpleCard}" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="翻译设置" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <TextBlock Text="源语言:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Text="{Binding SourceLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{ThemeResource DarkTextBox}" Width="140" />
                        <TextBlock Text="目标语言:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBox Text="{Binding TargetLanguages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{ThemeResource DarkTextBox}" Width="200" />
                        <Button Content="🚀 开始翻译" Command="{Binding TranslateCommand}" Style="{ThemeResource PrimaryButton}" Padding="16,6" />
                        <Button Content="📥 导出Excel" Command="{Binding ExportCommand}" Padding="14,6" Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" />
                    </StackPanel>
                    <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,8" Spacing="4">
                        <Border Padding="12,10" CornerRadius="8" Background="#F0FDF4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔔" FontSize="14" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding ProgressText}" FontSize="13" Foreground="#166534" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="22,2,0,0">
                                        <TextBlock Text="进度: " FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding ProgressPercentage, Converter={StaticResource StringFormat}, ConverterParameter='{}{0:F1}'}" FontSize="12" Foreground="#16A34A" FontWeight="Bold" />
                                        <TextBlock Text="%" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Content="✖ 取消" Command="{Binding CancelCommand}" Height="30" Padding="12,0" Background="#EF4444" Foreground="White" BorderThickness="0" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}" Value="{Binding ProgressPercentage, Mode=OneWay}" Minimum="0" Maximum="100" Height="4" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Style="{ThemeResource SimpleCard}" Padding="20,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="任务历史" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                        <Button Content="🔄 刷新" Command="{Binding RefreshHistoryCommand}" HorizontalAlignment="Right" Padding="12,6" Background="Transparent" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" FontSize="12" />
                    </Grid>
                    <Border Style="{ThemeResource SimpleCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,9">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="16" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="任务名称" Style="{ThemeResource TableHeaderText}" />
                                <TextBlock Grid.Column="1" Text="模式" Style="{ThemeResource TableHeaderText}" />
                                <TextBlock Grid.Column="2" Text="状态" Style="{ThemeResource TableHeaderText}" />
                                <TextBlock Grid.Column="3" Text="属性数" Style="{ThemeResource TableHeaderText}" />
                                <TextBlock Grid.Column="4" Text="时间" Style="{ThemeResource TableHeaderText}" />
                            </Grid>
                        </Border>
                        <ListView Grid.Row="1" ItemsSource="{Binding HistoryList}" Style="{ThemeResource TableListView}" ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="320">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,9" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="140" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TaskName}" Style="{ThemeResource TableCellText}" />
                                            <TextBlock Grid.Column="1" Text="{Binding QueryMode}" Style="{ThemeResource TableCellText}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Status}" Style="{ThemeResource TableCellText}" />
                                            <TextBlock Grid.Column="3" Text="{Binding TotalFields}" Style="{ThemeResource TableCellText}" />
                                            <TextBlock Grid.Column="4" Text="{Binding DisplayCreatedAt}" Style="{ThemeResource TableCellText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
</Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
