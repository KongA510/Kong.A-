<Page
    x:Class="ArasToolkit.App.WinUI.Views.TranslationHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="📜 翻译历史" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <TextBlock Text="历史翻译记录查询" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,0,0,20" />

            <Border Style="{ThemeResource SimpleCard}" Padding="20,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="全部记录" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                        </StackPanel>
                        <Button Content="🔄 刷新" Command="{Binding RefreshHistoryCommand}" HorizontalAlignment="Right" Padding="12,6" Background="Transparent" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" FontSize="12" />
                    </Grid>

                    <Border BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,9" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="源文件" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="1" Text="输出文件" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="2" Text="模板" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="3" Text="行数" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="4" Text="批次" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="5" Text="时间" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="6" Text="操作" Style="{ThemeResource TableHeaderText}" />
                        </Grid>
                    </Border>
                    <ListView ItemsSource="{Binding HistoryRecords}" Style="{ThemeResource TableListView}" ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="420">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,9" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SourceFileName}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="1" Text="{Binding OutputFileName}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding TemplateType}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="3" Text="{Binding SourceRowCount}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="4" Text="{Binding BatchCount}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="5" Text="{Binding CreatorOn, Converter={StaticResource DateTimeFormat}, ConverterParameter='yyyy-MM-dd HH:mm'}" Style="{ThemeResource TableCellText}" />
                                        <Button Grid.Column="6" Content="打开" Click="OpenFileButton_Click" Tag="{Binding}" Padding="8,3" FontSize="11" Background="Transparent" Foreground="#6366F1" BorderThickness="0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0" Spacing="8">
                        <Button Content="◀ 上一页" Command="{Binding PrevPageCommand}" Style="{ThemeResource PagingButton}" Width="80" />
                        <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <Button Content="下一页 ▶" Command="{Binding NextPageCommand}" Style="{ThemeResource PagingButton}" Width="80" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
