<Page
    x:Class="ArasToolkit.App.WinUI.Views.AppLoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource SystemBaseBrush}">
        <Border Style="{ThemeResource SimpleCard}"
                Width="380"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="36,32">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="🧰" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="个人工具箱"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="应用登录"
                           FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,28" />

                <!-- 账号 -->
                <TextBlock Text="账号" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,0,0,6" />
                <TextBox Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{ThemeResource DarkTextBox}" Margin="0,0,0,16" />

                <!-- 密码（WinUI PasswordBox.Password 可直接绑定） -->
                <TextBlock Text="密码" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,0,0,6" />
                <PasswordBox Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{ThemeResource DarkPasswordBox}" Margin="0,0,0,8" />

                <!-- 记住密码（仅登录模式） -->
                <CheckBox Content="记住密码"
                          IsChecked="{Binding RememberMe, Mode=TwoWay}"
                          Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13"
                          Margin="0,0,0,12"
                          Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVisibility}}" />

                <!-- 显示名称（注册模式） -->
                <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="显示名称" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{ThemeResource DarkTextBox}" Margin="0,0,0,16" />
                </StackPanel>

                <!-- 错误消息 -->
                <Border Background="#3FEF4444" CornerRadius="6" Padding="12,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"
                        Margin="0,0,0,12">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{ThemeResource ErrorBrush}"
                               FontSize="13" TextWrapping="Wrap" />
                </Border>

                <!-- 状态消息 -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,0,0,8"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />

                <!-- 登录按钮 -->
                <Button Content="登  录"
                        Command="{Binding LoginCommand}"
                        Style="{ThemeResource PrimaryButton}"
                        Height="44" FontSize="15" Margin="0,4,0,0" HorizontalAlignment="Stretch"
                        Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVisibility}}" />

                <!-- 注册按钮 -->
                <Button Content="注  册"
                        Command="{Binding RegisterCommand}"
                        Style="{ThemeResource PrimaryButton}"
                        Height="44" FontSize="15" Margin="0,4,0,0" HorizontalAlignment="Stretch"
                        Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibility}}" />

                <!-- 进度条 -->
                <ProgressBar Style="{ThemeResource DarkProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"
                             Margin="0,12,0,0" />

                <!-- 切换登录/注册 -->
                <Button Content="{Binding ToggleButtonText}"
                        Command="{Binding ToggleModeCommand}"
                        Background="Transparent" Foreground="{ThemeResource AccentBrush}"
                        BorderThickness="0" FontSize="13"
                        HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
