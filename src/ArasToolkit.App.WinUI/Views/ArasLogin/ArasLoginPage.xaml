<Page
    x:Class="ArasToolkit.App.WinUI.Views.ArasLoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Aras 登录信息管理" FontSize="26" FontWeight="Bold"
                           Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock Text="查看和管理已保存的 Aras 连接配置（连接成功后应用启动时自动连接）" FontSize="13"
                           Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,6,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="＋ 新增连接" Command="{Binding ToggleFormCommand}"
                    Style="{ThemeResource PrimaryButton}" Height="36" FontSize="13"
                    VerticalAlignment="Bottom" Padding="20,8" />
        </Grid>

        <!-- 新增/编辑表单（可折叠） -->
        <Border Grid.Row="1" Style="{ThemeResource CardStyle}" Padding="16,14" Margin="0,0,0,12"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="{Binding FormTitle}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,0,0,12" />

                <!-- URL -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="URL:" FontSize="13" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBox Grid.Column="1" Text="{Binding FormUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Style="{ThemeResource DarkTextBox}" />
                </Grid>

                <!-- 数据库 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="数据库:" FontSize="13" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBox Grid.Column="1" Text="{Binding FormDatabase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Style="{ThemeResource DarkTextBox}" />
                </Grid>

                <!-- 用户名 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="用户名:" FontSize="13" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBox Grid.Column="1" Text="{Binding FormUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Style="{ThemeResource DarkTextBox}" />
                </Grid>

                <!-- 密码 + 保存/取消 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="密码:" FontSize="13" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextSecondaryBrush}" />
                    <PasswordBox Grid.Column="1" x:Name="NewPasswordBox" FontSize="13"
                                 Style="{ThemeResource DarkPasswordBox}" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                        <Button Content="保存" Command="{Binding SaveCommand}"
                                Style="{ThemeResource PrimaryButton}" Height="30" FontSize="12" Padding="16,0" />
                        <Button Content="取消" Command="{Binding CancelEditCommand}"
                                Height="30" FontSize="12" Padding="16,0" Margin="6,0,0,0" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 连接列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater ItemsSource="{Binding LoginInfos}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="10" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{ThemeResource CardStyle}" Padding="14,12" HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Username}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}" />
                                        <TextBlock Text="@" FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding Database}" FontSize="14"
                                                   Foreground="{ThemeResource AccentBrush}" />
                                        <Border CornerRadius="3" Padding="6,2" Margin="8,0,0,0" Background="#DEF7EC"
                                                Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="✓ 已启用" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Url}" FontSize="11"
                                               Foreground="{ThemeResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="编辑" Tag="{Binding}" Click="EditButton_Click"
                                            Height="28" FontSize="12" Padding="12,0" />
                                    <Button Content="连接" Tag="{Binding}" Click="ConnectButton_Click"
                                            Style="{ThemeResource PrimaryButton}"
                                            Height="28" FontSize="12" Padding="14,0" Margin="6,0,0,0" />
                                    <Button Content="删除" Tag="{Binding}" Click="DeleteButton_Click"
                                            Height="28" FontSize="12" Padding="12,0" Margin="6,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- 状态栏 -->
        <Border Grid.Row="3" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{ThemeResource ErrorBrush}" FontSize="12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />
                <ProgressBar Style="{ThemeResource DarkProgressBar}" IsIndeterminate="True"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"
                             Margin="0,6,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
