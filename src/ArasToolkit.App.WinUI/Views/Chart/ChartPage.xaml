<Page
    x:Class="ArasToolkit.App.WinUI.Views.ChartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📊 数据报表" FontSize="26" FontWeight="Bold"
                       Foreground="{ThemeResource TextPrimaryBrush}" />
            <TextBlock Text="待办任务数据统计分析与可视化" FontSize="13"
                       Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,6,0,0" />
        </StackPanel>

        <!-- 工具栏 -->
        <Border Grid.Row="1" Style="{ThemeResource CardStyle}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 图表类型切换 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="图表类型：" VerticalAlignment="Center" FontSize="13"
                               Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding ChartTypeOptions}"
                              SelectedItem="{Binding SelectedChartType, Mode=TwoWay}"
                              Style="{ThemeResource DarkComboBox}" Width="140" />
                </StackPanel>

                <!-- 分隔线 -->
                <Border Grid.Column="1" Width="1" Background="{ThemeResource BorderBrush}" Margin="16,0" />

                <!-- 状态信息 -->
                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />

                <!-- 刷新按钮 -->
                <Button Grid.Column="3" Content="🔄 刷新" Command="{Binding RefreshCommand}"
                        Style="{ThemeResource PrimaryButton}" Height="32" FontSize="12" Padding="16,6" />
            </Grid>
        </Border>

        <!-- 图表区域 -->
        <Border Grid.Row="2" Style="{ThemeResource CardStyle}" Padding="12">
            <Grid>
                <!-- LiveCharts2 柱状图 -->
                <lvc:CartesianChart Series="{Binding Series}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}" />

                <!-- 加载中遮罩 -->
                <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                        Background="#33000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Border Background="#6366F1" CornerRadius="8" Padding="24,12"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⏳ 加载中..." FontSize="14" Foreground="White" />
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
