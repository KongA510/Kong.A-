<Page
    x:Class="ArasToolkit.App.WinUI.Views.LifecycleConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock Text="🔄 生命周期配置" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}" />
            <TextBlock Text="通过 Excel 批量创建 Aras 对象类的生命周期状态定义" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,4,0,0" />
        </StackPanel>
        <Border Grid.Row="1" Style="{ThemeResource CardStyle}" Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Command="{Binding DownloadTemplateCommand}" Content="📥 下载模板" Style="{ThemeResource PrimaryButton}" Height="32" Padding="16,0" />
                <Border Width="1" Background="{ThemeResource BorderBrush}" Margin="4,0" />
                <Button Content="📂 选择文件" Command="{Binding BrowseFileCommand}" Style="{ThemeResource AccentButton}" Height="32" Padding="12,0" />
                <TextBlock Text="{Binding FileName}" FontSize="13" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="模式:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                <ComboBox ItemsSource="{Binding ImportModeOptions}" SelectedItem="{Binding ImportMode, Mode=TwoWay}" Style="{ThemeResource DarkComboBox}" Width="90" />
                <Button Command="{Binding ExecuteImportCommand}" Content="▶ 执行导入" Style="{ThemeResource PrimaryButton}" Height="32" Padding="20,0" Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Spacing="8">
            <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" Padding="12,8" CornerRadius="8" Background="#F0F9FF">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#1E40AF" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            <StackPanel Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibility}}" Spacing="4">
                <Border Padding="12,10" CornerRadius="8" Background="#F0FDF4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding ProgressText}" FontSize="13" Foreground="#166534" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="22,2,0,0">
                                <TextBlock Text="总进度: " FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding ProgressPercentage, Converter={StaticResource StringFormat}, ConverterParameter='{}{0:F1}'}" FontSize="12" Foreground="#16A34A" FontWeight="Bold" />
                                <TextBlock Text="%" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕ 取消导入" Command="{Binding CancelImportCommand}" Height="30" Padding="12,0" Style="{ThemeResource PrimaryButton}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}" Value="{Binding ProgressPercentage, Mode=OneWay}" Minimum="0" Maximum="100" Height="4" />
            </StackPanel>
            <Border Background="#3FEF4444" CornerRadius="4" Padding="10,6" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" />
            </Border>
        </StackPanel>
        <Grid Grid.Row="3" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{ThemeResource CardStyle}" Padding="16,12" Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" Text="📊 导入结果" />
                    <StackPanel Margin="0,8,0,0" Spacing="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="生命周期新增: " FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding LastResult.Sheet1Count}" FontSize="13" FontWeight="Bold" Foreground="#16A34A" />
                            <TextBlock Text=" 条" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text=" (失败: " FontSize="13" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="{Binding LastResult.Sheet1Failed}" FontSize="13" FontWeight="Bold" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text=" 条)" FontSize="13" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="状态新增: " FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding LastResult.Sheet2Count}" FontSize="13" FontWeight="Bold" Foreground="#16A34A" />
                            <TextBlock Text=" 条" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text=" (失败: " FontSize="13" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="{Binding LastResult.Sheet2Failed}" FontSize="13" FontWeight="Bold" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text=" 条)" FontSize="13" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="转变新增: " FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding LastResult.Sheet3Count}" FontSize="13" FontWeight="Bold" Foreground="#16A34A" />
                            <TextBlock Text=" 条" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text=" (失败: " FontSize="13" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="{Binding LastResult.Sheet3Failed}" FontSize="13" FontWeight="Bold" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text=" 条)" FontSize="13" Foreground="#EF4444" Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                        <Button Content="📄 查看导入日志" Click="OpenLogFile_Click" Tag="{Binding LastResult.LogFilePath}" Padding="10,6" FontSize="12" Background="Transparent" Foreground="#6366F1" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Margin="0,6,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Style="{ThemeResource SimpleCard}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12,16,8" Spacing="12">
                        <TextBlock Text="📜 导入历史" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <Button Content="🔄 刷新" Command="{Binding RefreshHistoryCommand}" Height="26" FontSize="11" Padding="10,0" Style="{ThemeResource PrimaryButton}" />
                    </StackPanel>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,9">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="55" />
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="状态" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="1" Text="汇入时间" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="2" Text="文件" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="3" Text="生命周期" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="4" Text="状态" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="5" Text="转变" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="6" Text="备注" Style="{ThemeResource TableHeaderText}" />
                            <TextBlock Grid.Column="7" Text="操作" Style="{ThemeResource TableHeaderText}" />
                        </Grid>
                    </Border>
                    <ListView Grid.Row="2" ItemsSource="{Binding HistoryRecords}" Style="{ThemeResource TableListView}" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,9" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="55" />
                                            <ColumnDefinition Width="45" />
                                            <ColumnDefinition Width="45" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StatusText}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayImportTime}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ImportFile}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Sheet1Count}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Sheet2Count}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="5" Text="{Binding Sheet3Count}" Style="{ThemeResource TableCellText}" />
                                        <TextBlock Grid.Column="6" Text="{Binding Summary}" Style="{ThemeResource TableCellText}" />
                                        <Button Grid.Column="7" Content="打开" Click="OpenImportFile_Click" Tag="{Binding}" Padding="8,3" FontSize="11" Background="Transparent" Foreground="#6366F1" BorderThickness="0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <Button Content="◀ 上一页" Command="{Binding PrevPageCommand}" Style="{ThemeResource PagingButton}" Width="80" />
                <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                <Button Content="下一页 ▶" Command="{Binding NextPageCommand}" Style="{ThemeResource PagingButton}" Width="80" />
            </StackPanel>
        </Grid>
        <TextBlock Grid.Row="4" FontSize="11" Foreground="#9CA3AF" TextWrapping="Wrap" Text="提示：点击「下载模板」获取标准 Excel 模板，填写后上传执行导入。导入过程中可随时点击「取消导入」终止当前操作。" />
    </Grid>
</Page>
