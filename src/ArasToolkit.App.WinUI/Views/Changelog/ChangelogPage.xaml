<Page
    x:Class="ArasToolkit.App.WinUI.Views.ChangelogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="更新日志" FontSize="26" FontWeight="Bold"
                           Foreground="{ThemeResource TextPrimaryBrush}" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="当前版本：" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding CurrentVersion}" FontSize="14" FontWeight="Bold"
                               Foreground="{ThemeResource AccentBrush}" Margin="4,0,0,0" />
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshCommand}"
                    Style="{ThemeResource PrimaryButton}" Height="36" FontSize="13"
                    VerticalAlignment="Bottom" Padding="20,8" />
        </Grid>

        <!-- 统计卡片 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Style="{ThemeResource CardStyle}" Width="160" Margin="0,0,12,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="总计" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TotalCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{ThemeResource CardStyle}" Width="160" Margin="0,0,12,0" Padding="16,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource SuccessBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="新增" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding NewCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{ThemeResource SuccessBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{ThemeResource CardStyle}" Width="160" Margin="0,0,12,0" Padding="16,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource WarningBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="修复" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding FixCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{ThemeResource WarningBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{ThemeResource CardStyle}" Width="160" Margin="0,0,12,0" Padding="16,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#3B82F6" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="优化" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding OptimizeCount}" FontSize="24" FontWeight="Bold"
                               Foreground="#3B82F6" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 过滤工具栏 -->
        <Border Grid.Row="2" Style="{ThemeResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="筛选类型：" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13" Margin="0,0,12,0" />
                <ComboBox ItemsSource="{Binding FilterTypes}"
                          SelectedItem="{Binding FilterType, Mode=TwoWay}"
                          Style="{ThemeResource DarkComboBox}" Width="120" />
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                           Margin="16,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 日志列表 -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater ItemsSource="{Binding Entries}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{ThemeResource CardStyle}" Margin="0,0,0,10" Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="0,0,20,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Width="44" Height="44" CornerRadius="22"
                                            Background="{ThemeResource AccentBrush}"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Version, Converter={StaticResource StringFormat}, ConverterParameter='v{0}'}"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="White" TextTrimming="CharacterEllipsis"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Grid.Row="1" Width="2"
                                            Background="{ThemeResource BorderBrush}"
                                            HorizontalAlignment="Center" Margin="0,6,0,0" />
                                </Grid>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="📅" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding DisplayDate}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text=" · " Foreground="{ThemeResource BorderBrush}" FontSize="14" Margin="6,0" />
                                        <TextBlock Text="{Binding Version, Converter={StaticResource StringFormat}, ConverterParameter='v{0}'}"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Border Background="{Binding Type, Converter={StaticResource LogTypeToBrush}, ConverterParameter=bg}"
                                            CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Type}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding Type, Converter={StaticResource LogTypeToBrush}}" />
                                    </Border>

                                    <TextBlock Text="{Binding Description}" FontSize="14"
                                               Foreground="{ThemeResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" LineHeight="22" />

                                    <TextBlock Text="{Binding Author, Converter={StaticResource StringFormat}, ConverterParameter='—— {0}'}"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextSecondaryBrush}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
