<Page
    x:Class="ArasToolkit.App.WinUI.Views.DataImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="数据汇入" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}" />
            <TextBlock Text="Excel数据导入Aras系统" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- 文件选择 + 范围设置 -->
        <Border Grid.Row="1" Style="{ThemeResource CardStyle}" Padding="16,12">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="文件: " FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FileName}" FontSize="13" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <Button Content="浏览" Command="{Binding BrowseFileCommand}" Style="{ThemeResource PrimaryButton}" Height="28" Padding="12,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Sheet:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding SheetNames}" SelectedItem="{Binding SelectedSheetName, Mode=TwoWay}"
                              Style="{ThemeResource DarkComboBox}" Width="140" />
                    <TextBlock Text="起始行:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox Text="{Binding StartRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{ThemeResource DarkTextBox}" Width="55" />
                    <TextBlock Text="结束行:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBox Text="{Binding EndRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{ThemeResource DarkTextBox}" Width="55" />
                    <TextBlock Text="起始列:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBox Text="{Binding StartCol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{ThemeResource DarkTextBox}" Width="55" />
                    <TextBlock Text="结束列:" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBox Text="{Binding EndCol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{ThemeResource DarkTextBox}" Width="55" />
                    <Button Content="加载预览" Command="{Binding LoadPreviewCommand}" Style="{ThemeResource PrimaryButton}" Height="28" Padding="12,0" Margin="6,0,0,0" />
                    <TextBlock Text="线程" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                    <TextBox Text="{Binding MaxConcurrency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{ThemeResource DarkTextBox}" Width="42" TextAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 列映射表 -->
        <Border Grid.Row="2" Style="{ThemeResource CardStyle}" Padding="16,10"
                Visibility="{Binding HasColumnMappings, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Spacing="4">
                <TextBlock Text="列映射表 (@A @B ... → 真实列头)" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsRepeater ItemsSource="{Binding ColumnMappings}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="16" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Letter}" FontWeight="Bold" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBlock Text=" = " FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding Header}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- 数据预览 + AML 编辑器（左右分栏） -->
        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!-- 左：数据预览（代码后台动态渲染表格） -->
            <Border Grid.Column="0" Style="{ThemeResource SimpleCard}" Padding="0">
                <Grid>
                    <ScrollViewer x:Name="PreviewScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PreviewContainer" Orientation="Vertical" />
                    </ScrollViewer>
                    <TextBlock x:Name="PreviewPlaceholder" Text="请先加载预览" FontSize="14"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- 右：AML 编辑器 + 预览 -->
            <Border Grid.Column="1" Style="{ThemeResource CardStyle}" Padding="16,14">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="AML 模板" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <Button Content="选择配置" Command="{Binding OpenConfigSelectorCommand}" Style="{ThemeResource PrimaryButton}" Height="28" FontSize="11" Padding="10,0" Margin="6,0,0,0" />
                        <Button Content="保存" Command="{Binding SaveConfigCommand}" Style="{ThemeResource PrimaryButton}" Height="28" FontSize="11" Padding="10,0" />
                        <Button Content="预览" Command="{Binding PreviewAmlCommand}" Style="{ThemeResource PrimaryButton}" Height="28" FontSize="11" Padding="10,0" />
                    </StackPanel>

                    <TextBox Grid.Row="1" Text="{Binding AmlContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                             Style="{ThemeResource DarkTextBox}" Padding="10" MinHeight="100"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />

                    <TextBlock Grid.Row="2" Text="AML 预览" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               Visibility="{Binding PreviewResult, Converter={StaticResource StringToVisibility}}" />

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" MaxHeight="140"
                                  Visibility="{Binding PreviewResult, Converter={StaticResource StringToVisibility}}">
                        <Border Background="#F0F9FF" Padding="10" CornerRadius="4">
                            <TextBlock Text="{Binding PreviewResult}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap" />
                        </Border>
                    </ScrollViewer>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                        <Button Content="执行导入" Command="{Binding ExecuteImportCommand}"
                                Style="{ThemeResource AccentButton}" Height="32" Padding="20,0"
                                Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                        <Button Content="暂停" Command="{Binding PauseCommand}"
                                Height="32" Padding="16,0" Background="#F59E0B" Foreground="White" BorderThickness="0"
                                Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                        <Button Content="继续" Command="{Binding ResumeCommand}"
                                Style="{ThemeResource PrimaryButton}" Height="32" Padding="16,0"
                                Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="12"
                                Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar Value="{Binding ImportProgress, Mode=OneWay}" Minimum="0" Maximum="100" Height="6" Width="180" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态 -->
        <Border Grid.Row="4" Padding="0,4">
            <StackPanel Spacing="4">
                <Border Background="#3FEF4444" CornerRadius="4" Padding="8,4"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" />
                </Border>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <TextBlock FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                           Text="{Binding LastResult.LogFilePath, Converter={StaticResource StringFormat}, ConverterParameter='日志: {0}'}"
                           Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}" />
                <ProgressBar Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" IsIndeterminate="True" Height="4" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
