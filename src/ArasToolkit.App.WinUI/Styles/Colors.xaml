<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 浅色主题语义化色彩（沿用 WPF 版调色板，键名保持一致以便视图平迁） ===== -->

    <!-- 系统基础 / 侧边栏 -->
    <SolidColorBrush x:Key="SystemBaseBrush" Color="#F0F4F9" />
    <SolidColorBrush x:Key="SystemListLowBrush" Color="#F8F9FB" />
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="SidebarBgBrush" Color="#F8F9FB" />

    <!-- 强调色 -->
    <SolidColorBrush x:Key="SystemAccentBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="SystemAccentDark1Brush" Color="#005A9E" />
    <SolidColorBrush x:Key="SystemAccentLight1Brush" Color="#4DA2E8" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#005A9E" />

    <!-- 控件填充 -->
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="#E5E7EB" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#E5E7EB" />

    <!-- 卡片背景 -->
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />

    <!-- 文本 -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#111827" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#9CA3AF" />
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#D1D5DB" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280" />

    <!-- 边框 / 分隔 -->
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#E5E7EB" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#E5E7EB" />
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB" />

    <!-- 状态色 -->
    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="#10B981" />
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444" />

    <!-- 遮罩 -->
    <SolidColorBrush x:Key="SmokeFillColorDefaultBrush" Color="#99000000" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="#F3F4F6" />

    <!-- 圆角 -->
    <CornerRadius x:Key="AppControlCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>

</ResourceDictionary>
