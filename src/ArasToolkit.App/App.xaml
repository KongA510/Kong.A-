<Application x:Class="ArasToolkit.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 全局 Converter -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- 全局 Converter -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
            <converters:InverseBoolConverter x:Key="InverseBool" />
            <!-- 全局覆盖系统高亮色 -->
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D1D5DB" />
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E5E7EB" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111827" />
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#E5E7EB" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
