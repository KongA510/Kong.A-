<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ===== Fluent Design UI 主题入口 ===== -->
    <!-- 按顺序合并：色彩 → 控件 → 卡片 -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.Light.xaml" />
        <ResourceDictionary Source="Controls.xaml" />
        <ResourceDictionary Source="Cards.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ===== 全局 Window 样式 ===== -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource SystemBaseBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="AllowsTransparency" Value="True" />
    </Style>

    <!-- ===== 兼容旧 Key 别名（向后兼容） ===== -->
    <!-- 注意：不能用 Color="{DynamicResource}"，必须用 StaticResource 引用 SolidColorBrush -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource SystemBaseColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SystemFillColorNeutral}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource SystemAccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource SystemAccentColorDark1}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ControlFillColorTertiary}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardBackgroundFillColorDefault}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextFillColorSecondary}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ControlStrokeColorDefault}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SystemFillColorSuccess}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource SystemFillColorCritical}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource SystemFillColorCaution}" />
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SystemListLowColor}" />

    <!-- 向后兼容：旧样式名映射到新 Fluent 样式 -->
    <Style x:Key="DarkTextBox" TargetType="TextBox" BasedOn="{StaticResource FluentTextBox}" />
    <Style x:Key="DarkPasswordBox" TargetType="PasswordBox" BasedOn="{StaticResource FluentPasswordBox}" />
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource AccentButton}" />
    <Style x:Key="DarkDataGrid" TargetType="DataGrid" BasedOn="{StaticResource FluentDataGrid}" />
    <Style x:Key="DarkComboBox" TargetType="ComboBox" BasedOn="{StaticResource FluentComboBox}" />
    <Style x:Key="DarkCheckBox" TargetType="CheckBox" BasedOn="{StaticResource FluentCheckBox}" />
    <Style x:Key="DarkProgressBar" TargetType="ProgressBar" BasedOn="{StaticResource FluentProgressBar}" />
    <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource SimpleCard}" />

</ResourceDictionary>
