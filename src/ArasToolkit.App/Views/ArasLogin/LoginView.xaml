<UserControl x:Class="ArasToolkit.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- ===== 左侧：登录表单 ===== -->
        <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Style="{StaticResource CardStyle}" 
                    Width="420" 
                    Padding="40,36"
                    CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08" />
                </Border.Effect>

                <StackPanel>
                    <!-- Logo / Title -->
                    <TextBlock Text="Aras 工具箱" 
                               FontSize="28" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,4" />
                    <TextBlock Text="登录您的 Aras Innovator" 
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,28" />

                    <!-- 地址 -->
                    <TextBlock Text="服务器地址" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtUrl"
                             Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,16" />

                    <!-- 数据库 -->
                    <TextBlock Text="数据库" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtDatabase"
                             Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,16" />

                    <!-- 账户 -->
                    <TextBlock Text="账户" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtUsername"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,16" />

                    <!-- 密码 -->
                    <TextBlock Text="密码" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <PasswordBox x:Name="TxtPassword"
                                 Style="{StaticResource DarkPasswordBox}"
                                 Margin="0,0,0,8" />

                    <!-- 记住密码 -->
                    <CheckBox Content="记住登录信息" 
                              IsChecked="{Binding RememberMe}" 
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,0,0,16" />

                    <!-- 错误消息 -->
                    <Border Background="#3FEF4444" CornerRadius="6" Padding="12,8"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"
                            Margin="0,0,0,12">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" 
                                   FontSize="13" TextWrapping="Wrap" />
                    </Border>

                    <!-- 状态消息 -->
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,0,0,8"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />

                    <!-- 登录按钮 -->
                    <Button Content="登  录" 
                            Command="{Binding LoginCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            Height="44" FontSize="15" Margin="0,4,0,0" />

                    <!-- 登录动画进度条 -->
                    <ProgressBar Style="{StaticResource DarkProgressBar}"
                                 Visibility="{Binding IsLoggingIn, Converter={StaticResource BoolToVisibility}}"
                                 Margin="0,12,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== 分隔线 ===== -->
        <Border Grid.Column="1" Background="{StaticResource BorderBrush}" />

        <!-- ===== 右侧：已保存的登录记录 ===== -->
        <Border Grid.Column="2" Background="{StaticResource SecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0" 
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="20,20,20,14">
                    <StackPanel>
                        <TextBlock Text="已保存的登录" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="点击即可快速填充" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- 记录列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SavedLogins}" Margin="12,12,12,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RecordCard"
                                        Background="{StaticResource CardBrush}" 
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="16,14" Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="SavedLogin_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <!-- 用户名 @ 数据库 -->
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4">
                                                <Run Text="{Binding Username}" />
                                                <Run Text="@" Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Run Text="{Binding Database}" Foreground="{StaticResource AccentBrush}" />
                                            </TextBlock>
                                            <!-- URL -->
                                            <TextBlock Text="{Binding Url}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,0,0,2" />
                                            <!-- ConfigName -->
                                            <TextBlock Text="{Binding ConfigName}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Opacity="0.5" />
                                        </StackPanel>

                                        <!-- 删除按钮 -->
                                        <Button Grid.Column="1" Content="✕" 
                                                Tag="{Binding ConfigName}"
                                                Click="DeleteSavedLogin_Click"
                                                Background="Transparent"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                BorderThickness="0" FontSize="14"
                                                Cursor="Hand" Width="28" Height="28"
                                                VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 空状态提示 -->
                <TextBlock Grid.Row="1" 
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" LineHeight="22"
                           Visibility="{Binding HasSavedLogins, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <TextBlock.Text>
                        暂无保存的登录记录
                        勾选"记住登录信息"后自动保存
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
