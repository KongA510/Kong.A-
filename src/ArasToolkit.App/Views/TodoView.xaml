<UserControl x:Class="ArasToolkit.App.Views.TodoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d" d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
        <converters:ProgressToColorConverter x:Key="ProgressToColorConverter" />

        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Width" Value="300" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="PageBtn" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            
        </Style>
    </UserControl.Resources>
    <Grid>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: 顶栏 -->
        <Border Grid.Row="0" Background="White" Padding="20,14" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="个人任务" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DueTodayHint}" FontSize="12" Foreground="#EF4444"
                               VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="新增" Command="{Binding AddCommand}" Padding="14,6" Background="#6366F1"
                            Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13" />
                    <Button Content="📥 导入Excel" Command="{Binding ImportExcelCommand}" Padding="14,6"
                            Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand"
                            FontSize="13" Margin="8,0,0,0" />
                    <Button Content="📄 下载模板" Command="{Binding ExportTemplateCommand}" Padding="14,6"
                            Background="#8B5CF6" Foreground="White" BorderThickness="0" Cursor="Hand"
                            FontSize="13" Margin="8,0,0,0" />
                    <Button Padding="14,6" Background="#EF4444" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="13" Margin="16,0,0,0"
                            Command="{Binding BatchDeleteCommand}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="删除选中(" />
                                <TextBlock Text="{Binding SelectedCount}" />
                                <TextBlock Text=")" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: 搜索/过滤栏 -->
        <Border Grid.Row="1" Background="White" Padding="20,10" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="6" Padding="8,6"
                        BorderBrush="#E5E7EB" BorderThickness="1" Height="36">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding SearchKeyword, Delay=300}"
                                 BorderThickness="0" Background="Transparent" VerticalAlignment="Center" FontSize="13" />
                    </Grid>
                </Border>
                <ComboBox Grid.Column="1" ItemsSource="{Binding ProjectNameOptions}"
                          SelectedItem="{Binding FilterProjectName}"
                          Width="130" Height="36" Margin="8,0,0,0" FontSize="13" />
                <ComboBox Grid.Column="2" ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding FilterStatus}"
                          Width="100" Height="36" Margin="8,0,0,0" FontSize="13" />
            </Grid>
        </Border>

        <!-- Row 2: 卡片列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="#F8F9FB">
            <ItemsControl ItemsSource="{Binding Entries}" Margin="20,14,20,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource TaskCardStyle}" Cursor="Hand"
                                MouseLeftButtonDown="Card_MouseLeftButtonDown" Tag="{Binding}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#6366F1" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#E5E7EB" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Row 0: 复选框 + 任务名称 -->
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center" Margin="0,0,6,0"
                                              Checked="CardCheckBox_Changed" Unchecked="CardCheckBox_Changed" />
                                    <TextBlock Grid.Column="1" Text="{Binding TaskName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,3" />
                                </Grid>

                                <!-- Row 1: 项目名称(左) + 状态(右) -->
                                <Grid Grid.Row="1" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ProjectName}" FontSize="11"
                                               Foreground="{StaticResource AccentBrush}"
                                               Visibility="{Binding ProjectName, Converter={StaticResource StringToVisibility}}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <Border Grid.Column="1" CornerRadius="10" Padding="6,1" Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                </Grid>

                                <!-- Row 2: 进度条 + 百分比 -->
                                <Grid Grid.Row="2" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0" Value="{Binding CompletionPercent}"
                                                 Height="4" Minimum="0" Maximum="100" Background="#F3F4F6"
                                                 BorderThickness="0" VerticalAlignment="Center"
                                                 Foreground="{Binding CompletionPercent, Converter={StaticResource ProgressToColorConverter}}"
                                                 Style="{StaticResource DarkProgressBar}" />
                                    <TextBlock Grid.Column="1" Text="{Binding CompletionPercent, StringFormat={}{0}%}"
                                               FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="8,0,0,0" />
                                </Grid>

                                <!-- Row 3: 备注说明 -->
                                <TextBlock Grid.Row="3" Text="{Binding Remarks}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,4"
                                           Visibility="{Binding Remarks, Converter={StaticResource StringToVisibility}}" />

                                <!-- Row 4: 到期时间(左下) + 编辑/删除(右下) -->
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayDate}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource IconBtn}" Tag="{Binding}" Click="EditButton_Click"
                                                ToolTip="编辑">
                                            <TextBlock Text="✏" FontSize="12" />
                                        </Button>
                                        <Button Style="{StaticResource IconBtn}" Tag="{Binding}" Click="DeleteButton_Click"
                                                ToolTip="删除" Margin="4,0,0,0">
                                            <TextBlock Text="🗑" FontSize="12" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 3: 分页 -->
        <Border Grid.Row="3" Background="White" Padding="20,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⏮" Command="{Binding FirstPageCommand}" Style="{StaticResource PageBtn}" VerticalAlignment="Center" />
                <Button Content="◀" Command="{Binding PrevPageCommand}" Style="{StaticResource PageBtn}" Margin="4,0,0,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PageInfo}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,12,0" />
                <Button Content="▶" Command="{Binding NextPageCommand}" Style="{StaticResource PageBtn}" VerticalAlignment="Center" />
                <Button Content="⏭" Command="{Binding LastPageCommand}" Style="{StaticResource PageBtn}" Margin="4,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>

    <!-- 详情弹窗 -->
    <Border Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVisibility}}"
            Background="#99000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
            MouseLeftButtonDown="DetailPopupBg_MouseLeftButtonDown">
        <Border Width="480" Background="White" CornerRadius="12" Padding="24"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="任务详情" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource IconBtn}"
                            Width="30" Height="30" FontSize="16" Command="{Binding CloseDetailCommand}" />
                </Grid>

                <TextBlock Text="{Binding DetailItem.TaskName}" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="10" Padding="8,2"
                            Background="{Binding DetailItem.Status, Converter={StaticResource StatusToColorConverter}}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DetailItem.Status}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding DetailItem.ProjectName}" FontSize="13"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Visibility="{Binding DetailItem.ProjectName, Converter={StaticResource StringToVisibility}}" />
                </Grid>

                <TextBlock Text="{Binding DetailItem.Description}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Visibility="{Binding DetailItem.Description, Converter={StaticResource StringToVisibility}}" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Value="{Binding DetailItem.CompletionPercent}"
                                 Height="4" Minimum="0" Maximum="100" Background="#F3F4F6"
                                 BorderThickness="0" VerticalAlignment="Center"
                                 Foreground="{Binding DetailItem.CompletionPercent, Converter={StaticResource ProgressToColorConverter}}"
                                 Style="{StaticResource DarkProgressBar}" />
                    <TextBlock Grid.Column="1" Text="{Binding DetailItem.CompletionPercent, StringFormat={}{0}%}"
                               FontSize="15" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="10,0,0,0" />
                </Grid>

                <Border Background="#F9FAFB" CornerRadius="6" Padding="12,10" Margin="0,6,0,0">
                    <UniformGrid Columns="2">
                        <StackPanel>
                            <TextBlock Text="到期日" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding DetailItem.DisplayDate}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="创建日期" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding DetailItem.DisplayCreatedDate}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <TextBlock Text="{Binding DetailItem.Remarks}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                           Margin="0,6,0,0"
                           Visibility="{Binding DetailItem.Remarks, Converter={StaticResource StringToVisibility}}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="关闭" Command="{Binding CloseDetailCommand}" Padding="16,6"
                            Background="#6B7280" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13" />
                    <Button Content="编辑" Tag="{Binding DetailItem}" Click="DetailEditButton_Click"
                            Padding="16,6" Background="#6366F1" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="13" Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>

    <!-- 编辑面板 -->
    <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
            Background="#99000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border Width="520" Background="White" CornerRadius="12" Padding="28"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{Binding EditDialogTitle}" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                <TextBlock Text="任务名称 *" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox Text="{Binding EditingItem.TaskName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <TextBlock Text="项目名称" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox Text="{Binding EditingItem.ProjectName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <TextBlock Text="说明" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox Text="{Binding EditingItem.Description, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Height="60" TextWrapping="Wrap" AcceptsReturn="True" />

                <TextBlock Text="备注" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox Text="{Binding EditingItem.Remarks, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="到期日" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <DatePicker SelectedDate="{Binding EditingItem.ExpectedDate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="开始日期" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <DatePicker SelectedDate="{Binding EditingItem.StartDate}" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="状态" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding EditStatusOptions}" SelectedItem="{Binding EditingItem.Status}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="完成度(%)" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingItem.CompletionPercent, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Command="{Binding CancelCommand}" Padding="16,6"
                            Background="#6B7280" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13" />
                    <Button Content="保存" Command="{Binding SaveCommand}" Padding="16,6"
                            Background="#6366F1" Foreground="White" BorderThickness="0" Cursor="Hand"
                            FontSize="13" Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>

    <!-- 加载中 -->
    <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
            Background="#33000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border Background="#6366F1" CornerRadius="8" Padding="24,12"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="加载中..." FontSize="14" Foreground="White" />
        </Border>
    </Border>

    </Grid></UserControl>