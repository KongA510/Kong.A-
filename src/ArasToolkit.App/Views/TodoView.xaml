<UserControl x:Class="ArasToolkit.App.Views.TodoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d" d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
        <converters:ProgressToColorConverter x:Key="ProgressToColorConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />

        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Width" Value="350" />
            <Setter Property="Margin" Value="0,0,14,14" />
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>
    <Grid>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="24,16" Margin="0,0,0,0"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F4CB;" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Todo" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DueTodayHint}" FontSize="12"
                               Foreground="#EF4444" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding AddCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" />
                            <TextBlock Text="New Task" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ImportExcelCommand}"
                            Margin="8,0,0,0" Background="#10B981">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4C1;" Margin="0,0,6,0" />
                            <TextBlock Text="Import Excel" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ExportTemplateCommand}"
                            Margin="8,0,0,0" Background="#8B5CF6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4E5;" Margin="0,0,6,0" />
                            <TextBlock Text="Download Template" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Search & Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="24,12"
                BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="8" Padding="10,6"
                        BorderBrush="#E5E7EB" BorderThickness="1" Height="36">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" VerticalAlignment="Center"
                                 FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Grid>
                </Border>
                <ComboBox Grid.Column="1" ItemsSource="{Binding ProjectNameOptions}"
                          SelectedItem="{Binding FilterProjectName}" Width="140" Margin="10,0,0,0"
                          Height="36" FontSize="13" />
                <ComboBox Grid.Column="2" ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding FilterStatus}" Width="110" Margin="10,0,0,0"
                          Height="36" FontSize="13" />
                <Button Grid.Column="3" Content="Search" Command="{Binding ApplyFilterCommand}"
                        Style="{StaticResource ToolbarButton}" Height="36" Margin="10,0,0,0" />
            </Grid>
        </Border>

        <!-- Row 2: Card List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="#F8F9FB">
            <ItemsControl ItemsSource="{Binding Entries}" Margin="24,16,24,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource TaskCardStyle}" Cursor="Hand"
                                MouseLeftButtonDown="Card_MouseLeftButtonDown" Tag="{Binding}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#6366F1" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#E5E7EB" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Row 0: Checkbox + Task Name + Actions -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                              Checked="CardCheckBox_Changed" Unchecked="CardCheckBox_Changed" />
                                    <TextBlock Grid.Column="1" Text="{Binding TaskName}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Style="{StaticResource IconButton}" Tag="{Binding}" Click="EditButton_Click"
                                                ToolTip="Edit">
                                            <TextBlock Text="&#x270F;" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" Tag="{Binding}" Click="DeleteButton_Click"
                                                ToolTip="Delete" Margin="2,0,0,0">
                                            <TextBlock Text="&#x1F5D1;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 1: Project + Status -->
                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ProjectName}" FontSize="12"
                                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                               Visibility="{Binding ProjectName, Converter={StaticResource StringToVisibility}}" />
                                    <Border Grid.Column="2" CornerRadius="10" Padding="10,3"
                                            Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                </Grid>

                                <!-- Row 2: Description -->
                                <TextBlock Grid.Row="2" Text="{Binding Description}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" MaxHeight="36"
                                           TextWrapping="Wrap" Margin="0,0,0,8"
                                           Visibility="{Binding Description, Converter={StaticResource StringToVisibility}}" />

                                <!-- Row 3: Progress Bar -->
                                <Grid Grid.Row="3" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0" Value="{Binding CompletionPercent}"
                                                 Height="6" Minimum="0" Maximum="100"
                                                 Background="#F3F4F6" BorderThickness="0" VerticalAlignment="Center"
                                                 Foreground="{Binding CompletionPercent, Converter={StaticResource ProgressToColorConverter}}"
                                                 Style="{StaticResource DarkProgressBar}" />
                                    <TextBlock Grid.Column="1" Text="{Binding CompletionPercent, StringFormat={}{0}%}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" Margin="8,0,0,0" />
                                </Grid>

                                <!-- Row 4: Date -->
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayDate}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Remarks}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="8,0,0,0"
                                               Visibility="{Binding Remarks, Converter={StaticResource StringToVisibility}}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 3: Pagination -->
        <Border Grid.Row="3" Background="White" Padding="24,12"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="&#x23EE;" Command="{Binding FirstPageCommand}" Style="{StaticResource IconButton}"
                            Width="32" Height="32" />
                    <Button Content="&#x25C0;" Command="{Binding PrevPageCommand}" Style="{StaticResource IconButton}"
                            Width="32" Height="32" Margin="4,0,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding PageInfo}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="&#x25B6;" Command="{Binding NextPageCommand}" Style="{StaticResource IconButton}"
                            Width="32" Height="32" />
                    <Button Content="&#x23ED;" Command="{Binding LastPageCommand}" Style="{StaticResource IconButton}"
                            Width="32" Height="32" Margin="4,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

    <!-- Detail Popup Overlay -->
    <Border Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVisibility}}"
            Background="#99000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
            MouseLeftButtonDown="DetailPopupBg_MouseLeftButtonDown">
        <Border Width="500" Background="White" CornerRadius="16" Padding="28"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Task Detail" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <Button Grid.Column="1" Content="X" Style="{StaticResource IconButton}" Width="32" Height="32"
                            Command="{Binding CloseDetailCommand}" FontSize="16" />
                </Grid>

                <!-- Task Name -->
                <TextBlock Text="{Binding DetailItem.TaskName}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />

                <!-- Status + Project -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="10" Padding="10,4"
                            Background="{Binding DetailItem.Status, Converter={StaticResource StatusToColorConverter}}">
                        <TextBlock Text="{Binding DetailItem.Status}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding DetailItem.ProjectName}" FontSize="14"
                               Foreground="{StaticResource AccentBrush}" Margin="12,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding DetailItem.ProjectName, Converter={StaticResource StringToVisibility}}" />
                </Grid>

                <!-- Description -->
                <TextBlock Text="{Binding DetailItem.Description}" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                           Margin="0,0,0,12" MaxHeight="80"
                           Visibility="{Binding DetailItem.Description, Converter={StaticResource StringToVisibility}}" />

                <!-- Progress -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Value="{Binding DetailItem.CompletionPercent}"
                                 Height="8" Minimum="0" Maximum="100" Background="#F3F4F6"
                                 BorderThickness="0" VerticalAlignment="Center"
                                 Foreground="{Binding DetailItem.CompletionPercent, Converter={StaticResource ProgressToColorConverter}}"
                                 Style="{StaticResource DarkProgressBar}" />
                    <TextBlock Grid.Column="1" Text="{Binding DetailItem.CompletionPercent, StringFormat={}{0}%}"
                               FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="12,0,0,0" />
                </Grid>

                <!-- Dates -->
                <Border Background="#F9FAFB" CornerRadius="8" Padding="16,12" Margin="0,8,0,0">
                    <UniformGrid Columns="2">
                        <StackPanel>
                            <TextBlock Text="Due Date" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding DetailItem.DisplayDate}" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Created" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding DetailItem.DisplayCreatedDate}" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <!-- Remarks -->
                <TextBlock Text="{Binding DetailItem.Remarks}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding DetailItem.Remarks, Converter={StaticResource StringToVisibility}}" />

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Edit" Style="{StaticResource ToolbarButton}"
                            Tag="{Binding DetailItem}" Click="DetailEditButton_Click"
                            Background="#6366F1" />
                    <Button Content="Close" Command="{Binding CloseDetailCommand}"
                            Style="{StaticResource ToolbarButton}" Background="#6B7280" Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>

    <!-- Loading / Status Overlay -->
    <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
            Background="#33000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border Background="#6366F1" CornerRadius="8" Padding="24,12"
                HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..." FontSize="14" Foreground="White" />
            </Border>
    </Border>

    </Grid></UserControl>