<Window x:Class="ArasToolkit.App.Views.TranslationApiKeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 模型配置管理"
        Height="600" Width="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{StaticResource PrimaryBrush}"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button" x:Key="WindowButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <Style TargetType="Button" x:Key="AccentBtn">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="Button" x:Key="EditBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="Button" x:Key="DeleteBtn">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- 启用状态徽章 -->
        <Style TargetType="Border" x:Key="StatusBadge">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="&#x1F916; AI 模型配置管理" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="管理多个 AI 模型的 API Key，支持启用/切换" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,16" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="＋ 新增" Style="{StaticResource AccentBtn}" Height="28" FontSize="12" Padding="10,0" Margin="0,0,8,0"
                            Command="{Binding ToggleFormCommand}" />
                    <Button Content="✕" Style="{StaticResource WindowButton}" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <!-- 新增/编辑表单（可折叠） -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="14,12" Margin="0,0,0,12"
                    Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

                    <!-- Row 1: 模型名称 + 模型标识符 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="模型名称" FontSize="12"
                                   Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding NewModelName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" FontSize="12"
                                 Margin="0,0,10,0" ToolTip="如 Anges AI" />
                        <TextBlock Grid.Column="2" Text="模型标识符" FontSize="12"
                                   Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="3" Text="{Binding NewModelIdentifier, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" FontSize="12"
                                 ToolTip="如 agnes-2.0-flash" />
                    </Grid>

                    <!-- Row 2: API Base URL -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="API 地址" FontSize="12"
                                   Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding NewApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" FontSize="12"
                                 ToolTip="API 基础 URL" />
                    </Grid>

                    <!-- Row 3: API Key -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="API Key" FontSize="12"
                                   Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding NewApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" FontSize="12"
                                 ToolTip="API 密钥" />
                    </Grid>

                    <!-- Row 4: ExtraParams JSON -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="额外参数 JSON" FontSize="12"
                                   Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Top" Margin="0,4,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding NewExtraParams, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" FontSize="12"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="60" Height="Auto"
                                 ToolTip="粘贴 JSON 自定义参数，如 {&quot;max_completion_tokens&quot;:1024,&quot;temperature&quot;:1.0}" />
                    </Grid>

                    <!-- Row 5: 保存/取消按钮 -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="保存" Command="{Binding SaveCommand}"
                                    Style="{StaticResource AccentBtn}" Height="30" FontSize="12" Padding="14,0" />
                            <Button Content="取消" Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource EditBtn}" Height="30" FontSize="12" Padding="14,0" Margin="4,0,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 模型列表 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Models}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="14,12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <!-- 模型名称 -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding ModelName}" />
                                            <Border HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource StatusBadge}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Background" Value="#10B981"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                        <!-- 模型标识符 -->
                                        <TextBlock FontSize="11" Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,0,0,4">
                                            <Run Text="模型: " Foreground="{StaticResource TextSecondaryBrush}" />
                                            <Run Text="{Binding ModelIdentifier}" />
                                        </TextBlock>
                                        <!-- API URL -->
                                        <TextBlock Text="{Binding ApiBaseUrl}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />
                                        <!-- 创建时间 -->
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="创建: " />
                                            <Run Text="{Binding CreatorOn, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="启用" Style="{StaticResource AccentBtn}"
                                                Command="{Binding DataContext.EnableCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}" />
                                        <Button Content="编辑" Style="{StaticResource EditBtn}"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="删除" Style="{StaticResource DeleteBtn}"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 状态栏 -->
            <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0" Padding="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                               FontSize="12" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />
                    <ProgressBar Style="{StaticResource DarkProgressBar}"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"
                                 Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
