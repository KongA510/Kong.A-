<UserControl x:Class="ArasToolkit.App.Views.Translation.PropertyTranslationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- 标题 -->
            <TextBlock Text="&#x1F3F7;&#xFE0F; 属性翻译" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,4" />
            <TextBlock Text="Aras 对象类属性批量翻译工具" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,20" />

            <!-- 查询设置卡片 -->
            <Border Style="{StaticResource SimpleCard}" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="查询设置" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,12" />

                    <!-- 查询模式 + 对象类选择 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="查询模式:" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding QueryModes}"
                                  SelectedItem="{Binding SelectedQueryMode}"
                                  Width="120" FontSize="13" Height="30" />
                        <TextBlock Grid.Column="2" Text="对象类:" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="16,0,8,0" />
                        <ComboBox Grid.Column="3" ItemsSource="{Binding ItemTypeList}"
                                  SelectedItem="{Binding SelectedItemType}"
                                  DisplayMemberPath="Name"
                                  FontSize="13" Height="30" />
                        <Button Grid.Column="4" Content="&#x1F504; 加载对象类" Command="{Binding LoadItemTypesCommand}"
                                Padding="14,5" Margin="8,0,0,0"
                                Background="{DynamicResource SystemAccentBrush}"
                                Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="12" />
                    </Grid>

                    <!-- 加载属性按钮 -->
                    <Button Content="&#x1F4CB; 加载属性" Command="{Binding LoadPropertiesCommand}"
                            Padding="16,6" HorizontalAlignment="Left"
                            Background="{DynamicResource SystemAccentBrush}"
                            Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13" />
                </StackPanel>
            </Border>

            <!-- 属性列表卡片 -->
            <Border Style="{StaticResource SimpleCard}" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="属性列表" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text="{Binding PropertyList.Count, StringFormat='共 {0} 个属性'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <DataGrid ItemsSource="{Binding PropertyList}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              MaxHeight="300"
                              Margin="0,0,0,8">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="属性名称" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="标签" Binding="{Binding Label}" Width="*" />
                            <DataGridTextColumn Header="数据类型" Binding="{Binding DataType}" Width="100" />
                            <DataGridTextColumn Header="所属对象类" Binding="{Binding ItemTypeName}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- 翻译设置卡片 -->
            <Border Style="{StaticResource SimpleCard}" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="翻译设置" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,12" />

                    <!-- 源语言 + 目标语言 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="源语言:" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding SourceLanguage, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 FontSize="13" Height="30" VerticalContentAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="目标语言:" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="16,0,8,0" />
                        <TextBox Grid.Column="3" Text="{Binding TargetLanguages, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 FontSize="13" Height="30" VerticalContentAlignment="Center" />
                        <Button Grid.Column="4" Content="&#x1F680; 开始翻译" Command="{Binding TranslateCommand}"
                                Padding="16,6" Margin="8,0,0,0"
                                Background="{DynamicResource SystemAccentBrush}"
                                Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13" FontWeight="SemiBold" />
                        <Button Grid.Column="5" Content="&#x1F4E5; 导出Excel" Command="{Binding ExportCommand}"
                                Padding="14,6" Margin="8,0,0,0"
                                Background="Transparent"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" Cursor="Hand" FontSize="12" />
                    </Grid>

                    <!-- 进度区域 -->
                    <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,8">
                        <Border Padding="12,10" CornerRadius="8" Background="#F0FDF4" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F514;" FontSize="14" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding ProgressText}"
                                                   FontSize="13" Foreground="#166534"
                                                   VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="22,2,0,0">
                                        <TextBlock Text="进度: " FontSize="12" Foreground="#6B7280" />
                                        <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0:F1}}"
                                                   FontSize="12" Foreground="#16A34A" FontWeight="Bold" />
                                        <TextBlock Text="%" FontSize="12" Foreground="#6B7280" />
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Content="&#x2716; 取消"
                                        Command="{Binding CancelCommand}"
                                        Height="30" FontSize="12" Padding="12,0"
                                        Background="#EF4444" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                     Value="{Binding ProgressPercentage, Mode=OneWay}"
                                     Minimum="0" Maximum="100" Height="4"
                                     Style="{StaticResource FluentProgressBar}" />
                    </StackPanel>

                    <!-- 状态信息 -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- 任务历史卡片 -->
            <Border Style="{StaticResource SimpleCard}" Padding="20,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="任务历史" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Button Content="&#x1F504; 刷新" Command="{Binding RefreshHistoryCommand}"
                                HorizontalAlignment="Right" Padding="12,6"
                                Background="Transparent"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" Cursor="Hand" FontSize="12" />
                    </Grid>

                    <DataGrid ItemsSource="{Binding HistoryList}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              MaxHeight="250">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="任务名称" Binding="{Binding TaskName}" Width="*" />
                            <DataGridTextColumn Header="模式" Binding="{Binding QueryMode}" Width="80" />
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80" />
                            <DataGridTextColumn Header="属性数" Binding="{Binding TotalFields}" Width="60" />
                            <DataGridTextColumn Header="时间" Binding="{Binding DisplayCreatedAt}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
