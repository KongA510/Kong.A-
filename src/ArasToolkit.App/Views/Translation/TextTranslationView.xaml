<UserControl x:Class="ArasToolkit.App.Views.TextTranslationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- 标题 -->
            <TextBlock Text="&#x1F4DD; 文本翻译" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,4" />
            <TextBlock Text="AI 驱动的 Excel 批量翻译工具" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,20" />

            <!-- 翻译操作卡片 -->
            <Border Style="{StaticResource SimpleCard}" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Row 0: 文件选择 + 开始翻译 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MaxWidth="340" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x1F4C1; 源文件" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding SourceFilePath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 VerticalAlignment="Center" Height="30"
                                 Background="{DynamicResource ControlFillColorTertiaryBrush}" />
                        <Button Grid.Column="2" Content="浏览..." Command="{Binding BrowseSourceCommand}"
                                Padding="16,5" Margin="8,0,0,0"
                                Background="{DynamicResource SystemAccentBrush}"
                                Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13" />

                        <!-- 开始翻译（靠右，同色系紧跟浏览按钮） -->
                        <Button Grid.Column="3" Content="&#x1F680; 开始翻译"
                                Command="{Binding TranslateCommand}"
                                Padding="20,6" FontSize="14" FontWeight="SemiBold"
                                Height="34" Margin="8,0,0,0"
                                Background="{DynamicResource SystemAccentBrush}"
                                Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                MinWidth="140">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource SystemAccentBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTranslating}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Row 1: 翻译模式（靠左） / 源语言(居中) / 下载模板（靠右） -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="翻译模式:" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding TemplateTypes}"
                                  SelectedItem="{Binding SelectedTemplateType}"
                                  Width="140" FontSize="13" Height="30" />

                        <!-- 源语言选择（自定义翻译时显示） -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    Visibility="{Binding IsCustomMode, Converter={StaticResource BoolToVisibility}}"
                                    HorizontalAlignment="Left" Margin="12,0,0,0">
                            <TextBlock Text="源语言:" FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox ItemsSource="{Binding SourceLanguages}"
                                      SelectedItem="{Binding SelectedSourceLanguage}"
                                      Width="120" FontSize="13" Height="30" />
                        </StackPanel>

                        <!-- 下载模板（靠右） -->
                        <Button Grid.Column="3" Content="&#x1F4E5; 下载模板" Command="{Binding DownloadTemplateCommand}"
                                Padding="14,5" FontSize="12" Height="30"
                                Background="Transparent"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" Cursor="Hand" />
                    </Grid>

                    <!-- 「源文本自定义翻译」模式专属 UI -->
                    <StackPanel Visibility="{Binding IsSourceCustomMode, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                        <!-- Sheet 选择 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📊 Sheet:" FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding SheetNames}"
                                      SelectedItem="{Binding SelectedSheetName}"
                                      Width="180" FontSize="13" Height="30"
                                      Style="{StaticResource FluentComboBox}" />
                            <TextBlock Grid.Column="2" Text="（选完 Sheet 自动加载列）" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>

                        <!-- 数据列 / 翻译列 / 目标语言 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>

                            <!-- 数据列 -->
                            <TextBlock Grid.Column="0" Text="📥 数据列:" FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding SourceColumns}"
                                      SelectedItem="{Binding SelectedSourceColumn}"
                                      DisplayMemberPath="Label"
                                      Width="180" FontSize="13" Height="30"
                                      Style="{StaticResource FluentComboBox}" />

                            <!-- 翻译列 -->
                            <TextBlock Grid.Column="2" Text="📤 翻译列:" FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="12,0,6,0" />
                            <ComboBox Grid.Column="3" ItemsSource="{Binding TargetColumns}"
                                      SelectedItem="{Binding SelectedTargetColumn}"
                                      DisplayMemberPath="Label"
                                      Width="180" FontSize="13" Height="30"
                                      Style="{StaticResource FluentComboBox}" />

                            <!-- 目标语言 -->
                            <TextBlock Grid.Column="4" Text="🎯 目标语言:" FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="12,0,6,0" />
                            <ComboBox Grid.Column="5" ItemsSource="{Binding TargetLanguages}"
                                      SelectedItem="{Binding SelectedTargetLanguage}"
                                      Width="120" FontSize="13" Height="30"
                                      Style="{StaticResource FluentComboBox}" />
                        </Grid>

                        <!-- 源文本预览 + 复制 -->
                        <Border Padding="10,8" CornerRadius="6"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <TextBlock Text="📋 源文本预览" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button HorizontalAlignment="Right"
                                            Content="📋 复制" Command="{Binding CopySourceTextCommand}"
                                            Padding="10,3" FontSize="11" Height="26"
                                            Background="Transparent"
                                            Foreground="{DynamicResource SystemAccentBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1" Cursor="Hand"
                                            IsEnabled="{Binding HasSourceTextPreview}" />
                                </Grid>

                                <TextBox Grid.Row="1"
                                         Text="{Binding SourceTextPreview, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="60" MaxHeight="150"
                                         FontSize="12"
                                         FontFamily="Consolas"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                         Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                         BorderThickness="0" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 翻译进度区域（翻译中显示） -->
                    <StackPanel Visibility="{Binding IsTranslating, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                        <!-- 进度状态卡片 -->
                        <Border Padding="12,10" CornerRadius="8" Background="#F0FDF4" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- 左侧: 进度文字 + 百分比 -->
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding ProgressText}"
                                                   FontSize="13" Foreground="#166534"
                                                   VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="22,2,0,0">
                                        <TextBlock Text="进度: " FontSize="12" Foreground="#6B7280" />
                                        <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0:F1}}"
                                                   FontSize="12" Foreground="#16A34A" FontWeight="Bold" />
                                        <TextBlock Text="%" FontSize="12" Foreground="#6B7280" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- 右侧: 取消按钮 -->
                                <Button Grid.Column="1" Content="✕ 取消"
                                        Command="{Binding CancelCommand}"
                                        Height="30" FontSize="12" Padding="12,0"
                                        Background="#EF4444" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- 确定型进度条 -->
                        <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                     Value="{Binding ProgressPercentage, Mode=OneWay}"
                                     Minimum="0" Maximum="100"
                                     Height="4"
                                     Style="{StaticResource FluentProgressBar}" />
                    </StackPanel>

                    <!-- 状态信息 -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- 翻译历史卡片 -->
            <Border Style="{StaticResource SimpleCard}" Padding="20,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="翻译历史" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Button Content="&#x1F504; 刷新" Command="{Binding RefreshHistoryCommand}"
                                HorizontalAlignment="Right" Padding="12,6"
                                Background="Transparent"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Cursor="Hand" FontSize="12" />
                    </Grid>

                    <DataGrid ItemsSource="{Binding HistoryRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Margin="0,0,0,8">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="源文件" Binding="{Binding SourceFileName}" Width="*" />
                            <DataGridTextColumn Header="模板" Binding="{Binding TemplateType}" Width="80" />
                            <DataGridTextColumn Header="行数" Binding="{Binding SourceRowCount}" Width="60" />
                            <DataGridTextColumn Header="批次" Binding="{Binding BatchCount}" Width="60" />
                            <DataGridTextColumn Header="时间" Binding="{Binding CreatorOn, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140" />
                            <DataGridTemplateColumn Header="操作" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="打开" Click="OpenFileButton_Click"
                                                Tag="{Binding}"
                                                Padding="8,4" FontSize="11"
                                                Background="Transparent"
                                                Foreground="{DynamicResource SystemAccentBrush}"
                                                BorderThickness="0" Cursor="Hand" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
