<UserControl x:Class="ArasToolkit.App.Views.AppLoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Style="{StaticResource CardStyle}"
                    Width="400"
                    Padding="40,36"
                    CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08" />
                </Border.Effect>

                <StackPanel>
                    <!-- Logo / Title -->
                    <TextBlock Text="个人工具箱"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,4" />
                    <TextBlock Text="应用登录"
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,28" />

                    <!-- 账号 -->
                    <TextBlock Text="账号" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtUsername"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" Margin="0,0,0,16" />

                    <!-- 密码 -->
                    <TextBlock Text="密码" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <PasswordBox x:Name="TxtPassword"
                                 Style="{StaticResource DarkPasswordBox}"
                                 Margin="0,0,0,8" />

                    <!-- 记住密码（仅登录模式） -->
                    <CheckBox Content="记住密码"
                              IsChecked="{Binding RememberMe}"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="13"
                              Margin="0,0,0,12"
                              Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVisibility}}" />

                    <!-- 显示名称（注册模式） -->
                    <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="显示名称" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBox x:Name="TxtDisplayName"
                                 Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,16" />
                    </StackPanel>

                    <!-- 错误消息 -->
                    <Border Background="#3FEF4444" CornerRadius="6" Padding="12,8"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"
                            Margin="0,0,0,12">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                                   FontSize="13" TextWrapping="Wrap" />
                    </Border>

                    <!-- 状态消息 -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,0,0,8"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />

                    <!-- 登录按钮 -->
                    <Button Content="登  录"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="44" FontSize="15" Margin="0,4,0,0"
                            Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVisibility}}" />

                    <!-- 注册按钮 -->
                    <Button Content="注  册"
                            Command="{Binding RegisterCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="44" FontSize="15" Margin="0,4,0,0"
                            Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibility}}" />

                    <!-- 登录动画进度条 -->
                    <ProgressBar Style="{StaticResource DarkProgressBar}"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"
                                 Margin="0,12,0,0" />

                    <!-- 切换登录/注册 -->
                    <Button Content="{Binding ToggleButtonText}"
                            Command="{Binding ToggleModeCommand}"
                            Background="Transparent"
                            Foreground="{StaticResource AccentBrush}"
                            BorderThickness="0"
                            FontSize="13"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0"
                            Cursor="Hand" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
