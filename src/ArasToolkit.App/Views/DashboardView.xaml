<UserControl x:Class="ArasToolkit.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <!-- 页面标题 -->
            <TextBlock Text="仪表盘" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
            <TextBlock Text="Aras 开发工具箱" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,24" />

            <!-- 连接状态卡片组 -->
            <TextBlock Text="连接状态" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12" />

            <WrapPanel Margin="0,0,0,32">
                <!-- 连接状态 -->
                <Border Style="{DynamicResource ElevatedCard}" Width="210" Margin="0,0,12,12" Padding="20,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConnectionStatus}" Value="已连接">
                                                <Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConnectionStatus}" Value="未连接">
                                                <Setter Property="Fill" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ConnectionStatus}" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                        <TextBlock Text="连接状态" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- 服务器 -->
                <Border Style="{DynamicResource SimpleCard}" Width="210" Margin="0,0,12,12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{Binding ConnectedServer}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="服务器" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- 数据库 -->
                <Border Style="{DynamicResource SimpleCard}" Width="210" Margin="0,0,12,12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{Binding ConnectedDatabase}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="数据库" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- 用户 -->
                <Border Style="{DynamicResource SimpleCard}" Width="210" Margin="0,0,12,12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{Binding ConnectedUser}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="当前用户" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- 登录时间 -->
                <Border Style="{DynamicResource SimpleCard}" Width="210" Margin="0,0,12,12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{Binding LoginTime}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="登录时间" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- 全部功能入口 -->
            <TextBlock Text="全部功能" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,16" />

            <ItemsControl ItemsSource="{Binding AllFeatures}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="260" Margin="0,0,14,14"
                                Padding="20,18" Cursor="Hand"
                                MouseLeftButtonDown="FeatureCard_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding Icon}" FontSize="28" Margin="0,0,0,10" />
                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding Description}" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
