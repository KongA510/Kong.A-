<UserControl x:Class="ArasToolkit.App.Views.ObjectClassConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             xmlns:entities="clr-namespace:ArasToolkit.Core.Entities;assembly=ArasToolkit.Core"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="📦 对象类配置"
                       FontSize="24" FontWeight="Bold"
                       Foreground="#111827" />
            <TextBlock Text="通过 Excel 批量创建 Aras 对象类和关系类"
                       FontSize="13"
                       Foreground="#6B7280"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- 工具栏 -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Padding="16,12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 下载模板 -->
                <Button Grid.Column="0"
                        Command="{Binding DownloadTemplateCommand}"
                        Content="📥 下载模板"
                        Style="{StaticResource PrimaryButton}"
                        Height="32" FontSize="13"
                        Padding="16,0" />

                <!-- 分隔 -->
                <Border Grid.Column="1"
                        Width="1" Background="#E5E7EB"
                        Margin="16,0" />

                <!-- 文件选择 -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="📂 选择文件"
                            Command="{Binding BrowseFileCommand}"
                            Height="32" FontSize="13"
                            Padding="12,0"
                            Style="{StaticResource AccentButton}" />
                    <TextBlock Text="{Binding FileName}"
                               FontSize="13"
                               Foreground="#374151"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                </StackPanel>

                <!-- 执行导入 -->
                <Button Grid.Column="3"
                        Command="{Binding ExecuteImportCommand}"
                        Content="▶ 执行导入"
                        Style="{StaticResource PrimaryButton}"
                        Height="32" FontSize="13"
                        Padding="20,0"
                        Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
            </Grid>
        </Border>

        <!-- 状态信息 -->
        <Grid Grid.Row="2"
              Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}"
              Margin="0,0,0,8">
            <!-- 加载中 -->
            <Border Padding="12,8"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                    CornerRadius="8"
                    Background="#F0F9FF">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳"
                               FontSize="14"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13"
                               Foreground="#1E40AF"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- 进度条 -->
            <ProgressBar IsIndeterminate="True"
                         Height="3"
                         Style="{StaticResource FluentProgressBar}"
                         Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}" />
        </Grid>

        <!-- 错误提示 -->
        <Border Grid.Row="2"
                Background="#3FEF4444" CornerRadius="4"
                Padding="10,6" Margin="0,0,0,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#EF4444"
                       FontSize="12" />
        </Border>

        <!-- 主内容区：导入说明 + 历史记录 -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 导入结果卡片 -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardStyle}"
                    Padding="16,12"
                    Margin="0,0,0,12"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="SemiBold"
                               Foreground="#111827"
                               Text="导入结果" />
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="对象类新增: " FontSize="13" Foreground="#6B7280" />
                            <TextBlock Text="{Binding LastResult.Sheet1Count}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#6366F1" />
                            <TextBlock Text=" 条" FontSize="13" Foreground="#6B7280" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="关系类新增: " FontSize="13" Foreground="#6B7280" />
                            <TextBlock Text="{Binding LastResult.Sheet2Count}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#6366F1" />
                            <TextBlock Text=" 条" FontSize="13" Foreground="#6B7280" />
                        </StackPanel>
                        <TextBlock Text="{Binding LastResult.LogFilePath, StringFormat='日志: {0}'}"
                                   FontSize="11" Foreground="#9CA3AF"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 历史记录 -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Padding="16,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <TextBlock Text="📜 导入历史"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <Button Content="🔄 刷新"
                                Command="{Binding RefreshHistoryCommand}"
                                Height="26" FontSize="11"
                                Padding="10,0"
                                Margin="12,0,0,0"
                                Style="{StaticResource PrimaryButton}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding HistoryRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{StaticResource FluentDataGrid}"
                              MinHeight="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="状态"
                                                Binding="{Binding StatusText}"
                                                Width="60" />
                            <DataGridTextColumn Header="汇入时间"
                                                Binding="{Binding DisplayImportTime}"
                                                Width="150" />
                            <DataGridTextColumn Header="文件"
                                                Binding="{Binding ImportFile}"
                                                Width="200" />
                            <DataGridTextColumn Header="对象类"
                                                Binding="{Binding Sheet1Count}"
                                                Width="65" />
                            <DataGridTextColumn Header="关系类"
                                                Binding="{Binding Sheet2Count}"
                                                Width="65" />
                            <DataGridTextColumn Header="备注"
                                                Binding="{Binding Summary}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 无数据提示 -->
                    <TextBlock Grid.Row="1"
                               Text="暂无导入记录"
                               FontSize="14"
                               Foreground="#9CA3AF"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding HistoryRecords.Count, Converter={StaticResource StringToVis}, ConverterParameter=Invert}" />
                </Grid>
            </Border>
        </Grid>

        <!-- 底部说明 -->
        <Border Grid.Row="4" Margin="0,12,0,0">
            <TextBlock FontSize="11"
                       Foreground="#9CA3AF"
                       TextWrapping="Wrap"
                       Text="提示：点击「下载模板」获取标准 Excel 模板，填写后上传。系统将先建立对象类（Sheet1），再建立关系类（Sheet2），单线程执行确保安全。所有操作均记录审核日志。" />
        </Border>
    </Grid>
</UserControl>
