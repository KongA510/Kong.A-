<UserControl x:Class="ArasToolkit.App.Views.DatabaseExportConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="AccentBtn">
            <Setter Property="Background" Value="{DynamicResource SystemAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="Button" x:Key="EditBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="Button" x:Key="DeleteBtn">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Border" x:Key="StatusBadge">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28">

            <!-- 返回 + 标题 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button Content="← 返回" Click="BackButton_Click"
                        Style="{DynamicResource FluentButton}"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Padding="12,6" Cursor="Hand" FontSize="12" Margin="0,0,16,0" />
                <StackPanel>
                    <TextBlock Text="📤 数据库导出连接配置" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="管理多个数据库连接配置，支持启用/切换" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- 新增按钮 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="＋ 新增" Style="{StaticResource AccentBtn}" Height="28"
                        Command="{Binding ToggleFormCommand}" />
            </StackPanel>

            <!-- 新增/编辑表单 -->
            <Border Style="{DynamicResource SimpleCard}" Padding="14,12" Margin="0,0,0,12"
                    Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="配置名称" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding NewConfigName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource FluentTextBox}" FontSize="12" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="连接字符串" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding NewConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource FluentTextBox}" FontSize="12"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="备注" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding NewRemark, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource FluentTextBox}" FontSize="12" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="保存" Command="{Binding SaveCommand}"
                                Style="{StaticResource AccentBtn}" Height="30" FontSize="12" Padding="14,0" />
                        <Button Content="取消" Command="{Binding CancelEditCommand}"
                                Style="{StaticResource EditBtn}" Height="30" FontSize="12" Padding="14,0" Margin="4,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 配置列表 -->
            <ItemsControl ItemsSource="{Binding Configs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{DynamicResource SimpleCard}" Padding="14,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Text="{Binding ConfigName}" />
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadge}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Background" Value="#10B981"/><Setter Property="BorderThickness" Value="0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding ConnectionString}" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding Remark}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Visibility="{Binding Remark, Converter={StaticResource StringToVisibility}}"
                                               Margin="0,0,0,4" />
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="创建: "/>
                                        <Run Text="{Binding CreatorOn, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="启用" Style="{StaticResource AccentBtn}"
                                            Command="{Binding DataContext.EnableCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}" />
                                    <Button Content="编辑" Style="{StaticResource EditBtn}"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="删除" Style="{StaticResource DeleteBtn}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 状态栏 -->
            <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               FontSize="12" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="12" Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
