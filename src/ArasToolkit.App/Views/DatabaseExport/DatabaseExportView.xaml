<UserControl x:Class="ArasToolkit.App.Views.DatabaseExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="📤 数据库导出" FontSize="24" FontWeight="Bold" Foreground="#111827" />
                <TextBlock Text="执行SQL查询并将结果导出为Excel文件" FontSize="13" Foreground="#6B7280" Margin="0,4,0,0" />
            </StackPanel>

            <!-- 操作栏 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
                <WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="模板:" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}" DisplayMemberPath="TemplateName"
                                  Style="{StaticResource DarkComboBox}" Width="180" Height="32" FontSize="12" />
                        <Button Content="加载" Command="{Binding UseTemplateCommand}" Style="{StaticResource PrimaryButton}"
                                Height="32" FontSize="12" Padding="10,0" Margin="8,0,2,0" />
                        <Button Content="删除" Command="{Binding DeleteTemplateCommand}" Style="{StaticResource PrimaryButton}"
                                Height="32" FontSize="12" Padding="10,0" Margin="2,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="存为:" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Text="{Binding NewTemplateName, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource FluentTextBox}"
                                 Width="100" Height="32" FontSize="12" Padding="6,0" />
                        <Button Content="保存" Command="{Binding SaveTemplateCommand}" Style="{StaticResource PrimaryButton}"
                                Height="32" FontSize="12" Padding="10,0" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                        <TextBlock Text="模式:" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding ExportModeOptions}" SelectedItem="{Binding SelectedExportMode}"
                                  Style="{StaticResource DarkComboBox}" Width="100" Height="32" FontSize="13" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0"
                                Visibility="{Binding IsBatchMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="每批:" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}"
                                 Width="70" Height="32" FontSize="12" TextAlignment="Center" />
                        <TextBlock Text="条" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </StackPanel>
                    <Button Content="▶ 执行导出" Command="{Binding ExecuteExportCommand}" Height="32" FontSize="13" Padding="20,0"
                            Style="{StaticResource AccentButton}"
                            Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                </WrapPanel>
            </Border>

            <!-- SQL编辑区 -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="SQL查询语句" FontSize="14" FontWeight="SemiBold" Foreground="#111827" />
                        <TextBlock Text="（列的 AS 别名将作为 Excel 表头）" FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBox Text="{Binding SqlQuery, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="100" FontFamily="Consolas" FontSize="13" Padding="12,10" Style="{DynamicResource FluentTextBox}" />
                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="#9CA3AF" TextWrapping="Wrap">
                        <Run Text="目标数据库: "/><Run Text="{Binding ConnectionString}" />
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#9CA3AF" TextWrapping="Wrap"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}">
                        <Run Text="状态: "/><Run Text="{Binding StatusMessage}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 进度区 -->
            <StackPanel Grid.Row="3" Margin="0,0,0,8" Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}">
                <Border Padding="12,10" CornerRadius="8" Background="#F0FDF4">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding ProgressText, Mode=OneWay}" FontSize="13" Foreground="#166534" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="22,2,0,0">
                                <TextBlock Text="进度: " FontSize="12" Foreground="#6B7280" />
                                <TextBlock Text="{Binding ProgressPercentage, Mode=OneWay, StringFormat={}{0:F1}}" FontSize="12" Foreground="#16A34A" FontWeight="Bold" />
                                <TextBlock Text="%" FontSize="12" Foreground="#6B7280" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕ 取消导出" Command="{Binding CancelExportCommand}" Height="30" FontSize="12" Padding="12,0"
                                Style="{StaticResource PrimaryButton}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}" Value="{Binding ProgressPercentage, Mode=OneWay}" Minimum="0" Maximum="100"
                             Height="4" Style="{StaticResource FluentProgressBar}" Margin="0,4,0,0" />
            </StackPanel>

            <!-- 状态/错误 -->
            <StackPanel Grid.Row="4" Margin="0,0,0,8">
                <Border Background="#3FEF4444" CornerRadius="4" Padding="10,6" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" />
                </Border>
                <Border Background="#F0F9FF" CornerRadius="4" Padding="10,6" Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#1E40AF" FontSize="12" TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- 结果 + 历史 -->
            <Grid Grid.Row="5">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#111827" Text="📊 导出结果" />
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="总行: " FontSize="13" Foreground="#6B7280" />
                                <TextBlock Text="{Binding LastResult.TotalRows}" FontSize="13" FontWeight="Bold" Foreground="#111827" />
                                <TextBlock Text="　导出: " FontSize="13" Foreground="#6B7280" />
                                <TextBlock Text="{Binding LastResult.ExportedRows}" FontSize="13" FontWeight="Bold" Foreground="#16A34A" />
                                <TextBlock Text=" 行　文件: " FontSize="13" Foreground="#6B7280" />
                                <TextBlock Text="{Binding LastResult.BatchCount}" FontSize="13" FontWeight="Bold" Foreground="#111827" />
                                <TextBlock Text=" 个" FontSize="13" Foreground="#6B7280" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="📄 查看导出日志" Click="OpenLogFile_Click" Tag="{Binding LastResult.LogFilePath}"
                                        Padding="10,6" FontSize="12" Background="Transparent" Foreground="#6366F1"
                                        BorderBrush="#E5E7EB" BorderThickness="1" Cursor="Hand" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,14">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📜 导出历史" FontSize="14" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="12,0,0,0" />
                            <Button Content="🔄 刷新" Command="{Binding RefreshHistoryCommand}" Height="26" FontSize="11" Padding="10,0" Margin="12,0,0,0"
                                    Style="{StaticResource PrimaryButton}" />
                        </StackPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding HistoryRecords}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Style="{StaticResource FluentDataGrid}" MinHeight="120">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="55" />
                                <DataGridTextColumn Header="导出时间" Binding="{Binding DisplayExportTime}" Width="140" />
                                <DataGridTextColumn Header="模式" Binding="{Binding ExportMode}" Width="65" />
                                <DataGridTextColumn Header="行数" Binding="{Binding TotalRows}" Width="50" />
                                <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="200" />
                                <DataGridTemplateColumn Header="操作" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="打开" Click="OpenFileButton_Click"
                                                        Tag="{Binding}"
                                                        Padding="8,4" FontSize="11"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource SystemAccentBrush}"
                                                        BorderThickness="0" Cursor="Hand" />
                                                <Button Content="文件夹" Click="OpenFolderButton_Click"
                                                        Tag="{Binding}"
                                                        Padding="8,4" FontSize="11"
                                                        Background="Transparent"
                                                        Foreground="#6366F1"
                                                        BorderThickness="0" Cursor="Hand" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 分页 -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Content="◀ 上一页" Command="{Binding PrevPageCommand}" Style="{StaticResource PageBtn}" Width="80" Margin="0,0,8,0" />
                <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0" />
                <Button Content="下一页 ▶" Command="{Binding NextPageCommand}" Style="{StaticResource PageBtn}" Width="80" Margin="8,0,0,0" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
