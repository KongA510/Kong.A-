<UserControl x:Class="ArasToolkit.App.Views.ErrorLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="错误日志" FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="系统错误记录与排查" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- 筛选栏 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
            <WrapPanel>
                <TextBlock Text="级别:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding FilterLevels}" SelectedItem="{Binding FilterLevel}"
                          Style="{StaticResource DarkComboBox}" Width="100" Margin="0,0,16,0" />
                <TextBlock Text="从:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,6,0" />
                <DatePicker SelectedDate="{Binding FilterFromDate}" Width="140" Margin="0,0,16,0" />
                <TextBlock Text="到:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,6,0" />
                <DatePicker SelectedDate="{Binding FilterToDate}" Width="140" Margin="0,0,16,0" />
                <Button Content="筛选" Command="{Binding ApplyFilterCommand}"
                        Style="{StaticResource PrimaryButton}" Height="34" FontSize="13" Padding="16,6" Margin="0,0,8,0" />
                <Button Content="清空日志" Command="{Binding ClearCommand}"
                        Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0"
                        Height="34" FontSize="13" Cursor="Hand" Padding="16,6">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- 日志表格 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Entries}" Style="{StaticResource DarkDataGrid}"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserSortColumns="True" VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="调用功能" Binding="{Binding FunctionName}" Width="200" />
                <DataGridTextColumn Header="错误信息" Binding="{Binding ErrorMessage}" Width="*" />
                <DataGridTextColumn Header="记录日期" Binding="{Binding DisplayDate}" Width="170" />
                <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                    <Setter Property="Foreground" Value="#DC2626" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                    <Setter Property="Foreground" Value="#D97706" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 分页 -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="12,10" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding PageInfo}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⏮" Command="{Binding FirstPageCommand}"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Width="32" Height="32" Cursor="Hand" Margin="0,0,4,0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4" /></Style></Button.Resources>
                    </Button>
                    <Button Content="◀" Command="{Binding PrevPageCommand}"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Width="32" Height="32" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4" /></Style></Button.Resources>
                    </Button>
                    <Button Content="▶" Command="{Binding NextPageCommand}"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Width="32" Height="32" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4" /></Style></Button.Resources>
                    </Button>
                    <Button Content="⏭" Command="{Binding LastPageCommand}"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Width="32" Height="32" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4" /></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
