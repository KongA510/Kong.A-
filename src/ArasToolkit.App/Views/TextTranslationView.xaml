<UserControl x:Class="ArasToolkit.App.Views.TextTranslationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- 标题 -->
            <TextBlock Text="&#x1F4DD; 文本翻译" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,4" />
            <TextBlock Text="AI 驱动的 Excel 批量翻译工具" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,20" />

            <!-- 翻译操作卡片 -->
            <Border Style="{StaticResource SimpleCard}" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Row 0: 文件选择 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x1F4C1; 源文件" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding SourceFilePath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 IsReadOnly="True"
                                 Background="{DynamicResource ControlFillColorTertiaryBrush}" />
                        <Button Grid.Column="2" Content="浏览..." Command="{Binding BrowseSourceCommand}"
                                Padding="12,8" Margin="8,0,0,0"
                                Background="{DynamicResource SystemAccentBrush}"
                                Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13" />
                    </Grid>

                    <!-- Row 1: 翻译模式选择 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="翻译模式:" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding TemplateTypes}"
                                  SelectedItem="{Binding SelectedTemplateType}"
                                  Width="140" FontSize="13" />

                        <!-- 源语言选择（自定义翻译时显示） -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    Visibility="{Binding IsCustomMode, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="源语言:" FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,6,0" />
                            <ComboBox ItemsSource="{Binding SourceLanguages}"
                                      SelectedItem="{Binding SelectedSourceLanguage}"
                                      Width="120" FontSize="13" />
                        </StackPanel>

                        <!-- 下载模板 -->
                        <Button Grid.Column="3" Content="&#x1F4E5; 下载模板" Command="{Binding DownloadTemplateCommand}"
                                Padding="12,8" FontSize="12"
                                Background="Transparent"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" Cursor="Hand" />
                    </Grid>

                    <!-- Row 2: 翻译按钮 -->
                    <Grid Margin="0,0,0,12">
                        <Button Content="&#x1F680; 开始翻译"
                                Command="{Binding TranslateCommand}"
                                HorizontalAlignment="Left"
                                Padding="20,10" FontSize="14" FontWeight="SemiBold"
                                Background="{DynamicResource SystemAccentBrush}"
                                Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                MinWidth="140">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource SystemAccentBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTranslating}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Aras翻译说明 -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- 翻译历史卡片 -->
            <Border Style="{StaticResource SimpleCard}" Padding="20,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="翻译历史" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Button Content="&#x1F504; 刷新" Command="{Binding RefreshHistoryCommand}"
                                HorizontalAlignment="Right" Padding="12,6"
                                Background="Transparent"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Cursor="Hand" FontSize="12" />
                    </Grid>

                    <DataGrid ItemsSource="{Binding HistoryRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Margin="0,0,0,8">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="源文件" Binding="{Binding SourceFileName}" Width="*" />
                            <DataGridTextColumn Header="模板" Binding="{Binding TemplateType}" Width="80" />
                            <DataGridTextColumn Header="行数" Binding="{Binding SourceRowCount}" Width="60" />
                            <DataGridTextColumn Header="批次" Binding="{Binding BatchCount}" Width="60" />
                            <DataGridTextColumn Header="时间" Binding="{Binding CreatorOn, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140" />
                            <DataGridTemplateColumn Header="操作" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="打开" Click="OpenFileButton_Click"
                                                Tag="{Binding}"
                                                Padding="8,4" FontSize="11"
                                                Background="Transparent"
                                                Foreground="{DynamicResource SystemAccentBrush}"
                                                BorderThickness="0" Cursor="Hand" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
