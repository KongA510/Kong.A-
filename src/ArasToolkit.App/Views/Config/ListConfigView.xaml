<UserControl x:Class="ArasToolkit.App.Views.ListConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             xmlns:entities="clr-namespace:ArasToolkit.Core.Entities;assembly=ArasToolkit.Core"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVis" />

        <!-- 本地覆写 DataGrid 选中行背景为浅灰色 -->
        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: 标题区 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="📋 List配置" FontSize="24" FontWeight="Bold" Foreground="#111827" />
            <TextBlock Text="通过 Excel 批量创建 Aras List 主档、菜单内容、菜单过滤规则" FontSize="13" Foreground="#6B7280" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Row 1: 操作栏 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding DownloadTemplateCommand}"
                        Content="📥 下载模板" Style="{StaticResource PrimaryButton}"
                        Height="32" FontSize="13" Padding="16,0" />

                <Border Grid.Column="1" Width="1" Background="#E5E7EB" Margin="16,0" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📂 选择文件" Command="{Binding BrowseFileCommand}"
                            Height="32" FontSize="13" Padding="12,0"
                            Style="{StaticResource AccentButton}" />
                    <TextBlock Text="{Binding FileName}" FontSize="13" Foreground="#374151"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="模式:" FontSize="13" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding ImportModeOptions}"
                              SelectedItem="{Binding ImportMode}"
                              Style="{StaticResource DarkComboBox}"
                              Width="80" Height="34" FontSize="13" />
                </StackPanel>

                <Button Grid.Column="4" Command="{Binding ExecuteImportCommand}"
                        Content="▶ 执行导入" Style="{StaticResource PrimaryButton}"
                        Height="32" FontSize="13" Padding="20,0"
                        Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
            </Grid>
        </Border>

        <!-- Row 2: 状态 / 进度 / 错误区域 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">

            <!-- Loading 态 -->
            <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                    Padding="12,8" CornerRadius="8" Background="#F0F9FF">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                               Foreground="#1E40AF" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- 导入中态 -->
            <StackPanel Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}">
                <Border Padding="12,10" CornerRadius="8" Background="#F0FDF4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding ProgressText}"
                                           FontSize="13" Foreground="#166534"
                                           VerticalAlignment="Center" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="22,2,0,0">
                                <TextBlock Text="总进度: " FontSize="12" Foreground="#6B7280" />
                                <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0:F1}}"
                                           FontSize="12" Foreground="#16A34A" FontWeight="Bold" />
                                <TextBlock Text="%" FontSize="12" Foreground="#6B7280" />
                                <TextBlock Text="　错误: " FontSize="12" Foreground="#6B7280" Margin="16,0,0,0" />
                                <TextBlock Text="{Binding ImportErrorCount}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="#EF4444" />
                                <TextBlock Text=" 条" FontSize="12" Foreground="#6B7280" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Content="✕ 取消导入"
                                Command="{Binding CancelImportCommand}"
                                Height="30" FontSize="12" Padding="12,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                             Value="{Binding ProgressPercentage, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             Height="4"
                             Style="{StaticResource FluentProgressBar}" Margin="0,4,0,0" />
            </StackPanel>

            <!-- 错误态 -->
            <Border Background="#3FEF4444" CornerRadius="4" Padding="10,6"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444"
                           FontSize="12" TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <!-- Row 3: 结果 + 历史 -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 导入结果汇总 -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16,12"
                    Margin="0,0,0,12"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#111827"
                               Text="📊 导入结果" />
                    <StackPanel Margin="0,8,0,0">
                        <!-- List主档 -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="List主档: " FontSize="13" Foreground="#6B7280" />
                            <TextBlock Text="{Binding LastResult.Sheet1Count}"
                                       FontSize="13" FontWeight="Bold" Foreground="#16A34A" />
                            <TextBlock Text=" 条" FontSize="13" Foreground="#6B7280" />
                            <TextBlock Text=" (失败: " FontSize="13" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding LastResult.Sheet1Failed}"
                                       FontSize="13" FontWeight="Bold" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text=" 条)" FontSize="13" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <!-- 菜单内容 -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="菜单内容: " FontSize="13" Foreground="#6B7280" />
                            <TextBlock Text="{Binding LastResult.Sheet2Count}"
                                       FontSize="13" FontWeight="Bold" Foreground="#16A34A" />
                            <TextBlock Text=" 条" FontSize="13" Foreground="#6B7280" />
                            <TextBlock Text=" (失败: " FontSize="13" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding LastResult.Sheet2Failed}"
                                       FontSize="13" FontWeight="Bold" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text=" 条)" FontSize="13" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <!-- 菜单内容过滤 -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="菜单过滤: " FontSize="13" Foreground="#6B7280" />
                            <TextBlock Text="{Binding LastResult.Sheet3Count}"
                                       FontSize="13" FontWeight="Bold" Foreground="#16A34A" />
                            <TextBlock Text=" 条" FontSize="13" Foreground="#6B7280" />
                            <TextBlock Text=" (失败: " FontSize="13" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding LastResult.Sheet3Failed}"
                                       FontSize="13" FontWeight="Bold" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text=" 条)" FontSize="13" Foreground="#EF4444"
                                       Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <!-- 查看日志 -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="📄 查看导入日志" Click="OpenLogFile_Click"
                                    Tag="{Binding LastResult.LogFilePath}"
                                    Padding="10,6" FontSize="12"
                                    Background="Transparent"
                                    Foreground="#6366F1"
                                    BorderBrush="#E5E7EB" BorderThickness="1"
                                    Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 历史记录 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="📜 导入历史" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="{Binding PageInfo}" FontSize="12"
                                   Foreground="#6B7280" VerticalAlignment="Center" Margin="12,0,0,0" />
                        <Button Content="🔄 刷新" Command="{Binding RefreshHistoryCommand}"
                                Height="26" FontSize="11" Padding="10,0" Margin="12,0,0,0"
                                Style="{StaticResource PrimaryButton}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding HistoryRecords}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Style="{StaticResource FluentDataGrid}" MinHeight="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="60" />
                            <DataGridTextColumn Header="汇入时间" Binding="{Binding DisplayImportTime}" Width="150" />
                            <DataGridTextColumn Header="文件" Binding="{Binding ImportFile}" Width="200" />
                            <DataGridTextColumn Header="主档" Binding="{Binding Sheet1Count}" Width="55" />
                            <DataGridTextColumn Header="菜单" Binding="{Binding Sheet2Count}" Width="55" />
                            <DataGridTextColumn Header="过滤" Binding="{Binding Sheet3Count}" Width="55" />
                            <DataGridTextColumn Header="备注" Binding="{Binding Summary}" Width="*" />
                            <DataGridTemplateColumn Header="操作" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="打开" Click="OpenImportFile_Click"
                                                Tag="{Binding}"
                                                Padding="8,4" FontSize="11"
                                                Background="Transparent"
                                                Foreground="#6366F1"
                                                BorderThickness="0" Cursor="Hand" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 分页 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,8,0,0">
                <Button Content="◀ 上一页" Command="{Binding PrevPageCommand}"
                        Style="{StaticResource PageBtn}" Width="80" Margin="0,0,8,0" />
                <TextBlock Text="{Binding PageInfo}" FontSize="12"
                           Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0" />
                <Button Content="下一页 ▶" Command="{Binding NextPageCommand}"
                        Style="{StaticResource PageBtn}" Width="80" Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- Row 4: 提示信息 -->
        <Border Grid.Row="4" Margin="0,12,0,0">
            <TextBlock FontSize="11" Foreground="#9CA3AF" TextWrapping="Wrap"
                       Text="提示：点击「下载模板」获取标准 Excel 模板（3个Sheet），填写后上传。导入顺序: List主档 → 菜单内容 → 菜单内容(过滤)。导入过程中可随时点击「取消导入」终止当前操作。" />
        </Border>
    </Grid>
</UserControl>
