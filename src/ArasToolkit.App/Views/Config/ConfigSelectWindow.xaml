<Window x:Class="ArasToolkit.App.Views.ConfigSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择AML配置"
        Height="360" Width="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{StaticResource PrimaryBrush}"
        ResizeMode="NoResize">

    <Border CornerRadius="8" Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="选择AML配置" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />
                <Button Grid.Column="1" Content="✕" Click="CloseButton_Click"
                        Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                        BorderThickness="0" FontSize="16" Cursor="Hand" Width="28" Height="28" />
            </Grid>

            <!-- 配置列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ConfigList" ItemsSource="{Binding SavedConfigs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="12,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ConfigName}" FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding CreatorOn, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="选择" Click="SelectConfig_Click"
                                                Tag="{Binding}"
                                                Background="{StaticResource AccentBrush}"
                                                Foreground="White"
                                                BorderThickness="0" Padding="12,5" FontSize="12"
                                                Cursor="Hand" Margin="0,0,4,0" />
                                        <Button Content="删除" Click="DeleteConfig_Click"
                                                Tag="{Binding}"
                                                Background="#EF4444" Foreground="White"
                                                BorderThickness="0" Padding="12,5" FontSize="12"
                                                Cursor="Hand" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 底部 -->
            <Button Grid.Row="2" Content="取消" Click="CloseButton_Click"
                    Margin="0,8,0,0" Height="32"
                    Background="Transparent"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Cursor="Hand" FontSize="13" />
        </Grid>
    </Border>
</Window>
