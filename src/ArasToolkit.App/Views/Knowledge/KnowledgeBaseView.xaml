<UserControl x:Class="ArasToolkit.App.Views.KnowledgeBaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
             Background="Transparent"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />

        <!-- 格式化工具栏按钮样式 -->
        <Style TargetType="Button" x:Key="ToolbarBtn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#D1D5DB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 笔记卡片样式 -->
        <Style TargetType="Border" x:Key="NoteCard">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Background" Value="#F8F9FB" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 分类项样式 -->
        <Style TargetType="ListBoxItem" x:Key="CategoryItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="4,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E0E7FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标签样式 -->
        <Style TargetType="TextBlock" x:Key="TagLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#E0E7FF" />
            <Setter Property="Padding" Value="4,2" />
        </Style>

        <!-- 选中的卡片边框 -->
        <Style TargetType="Border" x:Key="NoteCardSelected" BasedOn="{StaticResource NoteCard}">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: 标题栏 -->
        <Grid Grid.Row="0" Margin="24,20,24,0">
            <StackPanel>
                <TextBlock Text="📚 个人资料库" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="知识笔记管理与富文本编辑" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>

            <!-- 查看/编辑态返回按钮 -->
            <Button Content="← 返回列表" Style="{StaticResource IconBtn}"
                    Command="{Binding BackToBrowseCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    FontSize="12" Padding="8,4"
                    Visibility="{Binding IsBrowseMode, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
        </Grid>

        <!-- Row 1: 顶部分隔线 -->
        <Border Grid.Row="1" Height="1" Background="{StaticResource BorderBrush}" Margin="0,12,0,0"
                VerticalAlignment="Top" />

        <!-- Row 1: 主内容区（左右双栏 + GridSplitter） -->
        <Grid Grid.Row="1" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="200" MaxWidth="400" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <!-- ===== 左栏：分类列表 ===== -->
            <Grid Grid.Column="0" Margin="24,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 搜索框 -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                   VerticalAlignment="Center" Margin="4,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 FontSize="13" VerticalAlignment="Center"
                                 Foreground="{StaticResource TextPrimaryBrush}" />
                        <Button Grid.Column="2" Content="✕" Style="{StaticResource ToolbarBtn}"
                                FontSize="10" Width="22" Height="22"
                                Click="ClearSearch_Click"
                                Visibility="{Binding SearchKeyword, Converter={StaticResource StringToVisibility}}" />
                    </Grid>
                </Border>

                <!-- 分类标题 -->
                <TextBlock Grid.Row="1" Text="📂 分类" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="4,0,0,8" />

                <!-- 分类列表 -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         ItemContainerStyle="{StaticResource CategoryItem}"
                         BorderThickness="0" Background="Transparent"
                         SelectionChanged="CategoryList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 新建按钮 -->
                <Button Grid.Row="3" Content="＋ 新建笔记" Style="{StaticResource AccentButton}"
                        Command="{Binding NewEntryCommand}"
                        HorizontalAlignment="Stretch" Margin="0,12,0,12"
                        Height="32" FontSize="12" Padding="0" FontWeight="Normal" />
            </Grid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1,0,0,0" />

            <!-- ===== 右栏：三态面板 ===== -->

            <!-- ▸ 浏览态：笔记卡片列表 -->
            <Grid Grid.Column="2" Margin="4,12,24,0"
                  Visibility="{Binding IsBrowseMode, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 分类标题 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,0,0,8">
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="{Binding SelectedCategory, Mode=OneWay}" />
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text=" (" />
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding TotalCount, Mode=OneWay}" />
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text=")" />
                </StackPanel>

                <!-- 空状态提示 -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,60,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TotalCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📝" FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="此分类下暂无笔记" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0" />
                    <TextBlock Text="点击左侧「＋ 新建笔记」开始记录" FontSize="12"
                               Foreground="{StaticResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <!-- 笔记卡片列表 -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding NotesInCategory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border MouseLeftButtonDown="NoteCard_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource CardBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="8" />
                                            <Setter Property="Padding" Value="12,10" />
                                            <Setter Property="Margin" Value="0,0,0,8" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="Background" Value="#F0F1FF" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    <Setter Property="Background" Value="#F8F9FB" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <!-- 第1行：标题 + 置顶标记 -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📌" FontSize="11" Margin="0,0,6,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding Pinned, Converter={StaticResource BoolToVisibility}}" />
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- 第2行：分类 + 标签 -->
                                        <WrapPanel Margin="0,6,0,0">
                                            <TextBlock Text="{Binding Category}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,8,0"
                                                       Visibility="{Binding Category, Converter={StaticResource StringToVisibility}}" />
                                            <TextBlock Text="{Binding DisplayTags}" Style="{StaticResource TagLabel}"
                                                       Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibility}}" />
                                        </WrapPanel>

                                        <!-- 第3行：预览文本 -->
                                        <TextBlock Text="{Binding PlainTextPreview}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxHeight="32"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding PlainTextPreview, Converter={StaticResource StringToVisibility}}" />

                                        <!-- 第4行：日期 -->
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource TextFillColorTertiaryBrush}"
                                                   Margin="0,6,0,0"
                                                   Text="{Binding DisplayModifiedDate, Mode=OneWay, StringFormat='{}{0} 修改'}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ▸ 查看态：只读预览 -->
            <Grid Grid.Column="2" Margin="4,12,24,0"
                  Visibility="{Binding IsViewMode, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 工具栏 -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,8" CornerRadius="8,8,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="✏️ 编辑" Style="{StaticResource AccentButton}"
                                Command="{Binding EnterEditCommand}"
                                Width="70" Height="28" FontSize="12" Padding="0" FontWeight="Normal"
                                Margin="0,0,8,0" />
                        <Button Content="🗑️ 删除" Command="{Binding DeleteFromViewCommand}"
                                Width="70" Height="28" FontSize="12"
                                Background="#FEE2E2" Foreground="#DC2626"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#FECACA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- 元数据区 -->
                <Border Grid.Row="1" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,0"
                        Padding="16,12">
                    <WrapPanel>
                        <!-- 标题 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,4">
                            <TextBlock Text="标题：" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ViewingEntry.Title}" FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- 置顶标记 -->
                        <Border Background="#FFF3E0" CornerRadius="4" Padding="6,2"
                                Margin="0,0,16,4"
                                Visibility="{Binding ViewingEntry.Pinned, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="📌 已置顶" FontSize="11"
                                       Foreground="#E65100" />
                        </Border>

                        <!-- 分类 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,4"
                                    Visibility="{Binding ViewingEntry.Category, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="分类：" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ViewingEntry.Category}" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- 标签 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,4"
                                    Visibility="{Binding ViewingEntry.HasTags, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="标签：" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding ViewingEntry.DisplayTags}" Style="{StaticResource TagLabel}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- 日期 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="最后修改：" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding ViewingEntry.DisplayModifiedDate}" FontSize="12"
                                       Foreground="{StaticResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <!-- 分隔线 -->
                <Border Grid.Row="2" Height="1" Background="{StaticResource BorderBrush}" />

                <!-- 只读 FlowDocument -->
                <Border Grid.Row="3" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1"
                        CornerRadius="0,0,8,8">
                    <FlowDocumentScrollViewer x:Name="ViewFlowDocumentScrollViewer"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="20,16"
                                             IsToolBarVisible="False" />
                </Border>
            </Grid>

            <!-- ▸ 编辑态：RichTextBox 编辑器 -->
            <Border Grid.Column="2" Background="{StaticResource SystemBaseBrush}"
                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                <Grid Margin="20,12,24,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 编辑工具栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="💾 保存" Style="{StaticResource AccentButton}"
                                Command="{Binding SaveEntryCommand}"
                                Width="70" Height="28" FontSize="12" Padding="0" FontWeight="Normal" Margin="0,0,8,0" />
                        <Button Content="❌ 取消" Command="{Binding CancelEditCommand}"
                                Width="70" Height="28" FontSize="12"
                                Background="#E5E7EB" Foreground="{StaticResource TextPrimaryBrush}"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#D1D5DB" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border Width="1" Height="20" Background="{StaticResource BorderBrush}" Margin="12,0" />
                        <Button Content="📷 插入图片" Style="{StaticResource ToolbarBtn}"
                                Width="Auto" FontSize="12" Padding="8,0"
                                Command="{Binding InsertImageCommand}" />
                        <Border Width="1" Height="20" Background="{StaticResource BorderBrush}" Margin="12,0" />
                        <!-- 文字格式工具栏 -->
                        <Button Content="B" Style="{StaticResource ToolbarBtn}"
                                FontWeight="Bold" Click="BoldButton_Click" />
                        <Button Content="I" Style="{StaticResource ToolbarBtn}"
                                FontStyle="Italic" Click="ItalicButton_Click" />
                        <Button Style="{StaticResource ToolbarBtn}"
                                Click="UnderlineButton_Click">
                            <TextBlock Text="U" TextDecorations="Underline" />
                        </Button>
                        <Button Content="• 列表" Style="{StaticResource ToolbarBtn}"
                                Width="Auto" FontSize="12" Padding="6,0"
                                Click="BulletListButton_Click" />
                    </StackPanel>

                    <!-- 编辑表单 -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 标题 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,6">
                            <TextBlock Text="标题" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,2" />
                            <TextBox Text="{Binding EditorTitle, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16" FontWeight="SemiBold" Padding="8,6"
                                     Style="{StaticResource FluentTextBox}" />
                        </StackPanel>

                        <!-- 置顶复选框 -->
                        <CheckBox Grid.Row="0" Grid.Column="1"
                                  IsChecked="{Binding EditorIsPinned}"
                                  Content="置顶" FontSize="12" VerticalAlignment="Bottom"
                                  Margin="12,0,0,6"
                                  Foreground="{StaticResource TextSecondaryBrush}" />

                        <!-- 标签 + 分类 -->
                        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="标签（逗号分隔）" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" />
                                <TextBox Text="{Binding EditorTags, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,5"
                                         Style="{StaticResource FluentTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="分类" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" />
                                <TextBox Text="{Binding EditorCategory, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,5"
                                         Style="{StaticResource FluentTextBox}" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- RichTextBox 编辑器 -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Background="White">
                        <RichTextBox x:Name="EditorRichTextBox"
                                     BorderThickness="0"
                                     Padding="16"
                                     FontSize="14"
                                     FontFamily="Microsoft YaHei"
                                     VerticalScrollBarVisibility="Auto"
                                     AcceptsTab="True"
                                     TextChanged="EditorRichTextBox_TextChanged"
                                     PreviewKeyDown="EditorRichTextBox_PreviewKeyDown" />
                    </Border>

                    <!-- 底部状态 -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 2: 底部状态栏 -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="24,8" Margin="24,0">
            <Grid>
                <TextBlock Text="{Binding PageInfo}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="3" Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" />
                <TextBlock Text="加载中..." FontSize="14"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
