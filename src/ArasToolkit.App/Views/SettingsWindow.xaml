<Window x:Class="ArasToolkit.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{StaticResource PrimaryBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button" x:Key="SettingsButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
        </Style>
    </Window.Resources>
    <Border CornerRadius="8" Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#x2699;&#xFE0F; 设置" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="&#x2715;" Click="CloseButton_Click"
                        Width="32" Height="32" Background="Transparent"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        BorderThickness="0" Cursor="Hand" FontSize="16"/>
            </Grid>

            <!-- Settings Content -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <!-- AI API Key -->
                <Border Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="&#x1F511; AI API Key" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Anges AI 调度密钥（用于文本翻译功能）" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="保存"
                                    Command="{Binding SaveApiKeyCommand}">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource SettingsButtonStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSavingApiKey}" Value="True">
                                                <Setter Property="Content" Value="保存中..."/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                        <TextBox Grid.Row="1" Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 Margin="0,8,0,0"/>
                    </Grid>
                </Border>

                <!-- Database Check -->
                <Border Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="&#x1F50D; 数据库检查" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="检查数据库表结构完整性，同步缺失字段" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="执行检查"
                                Command="{Binding CheckDatabaseCommand}"
>
                            <Button.Style>
                                <Style BasedOn="{StaticResource SettingsButtonStyle}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCheckingDb}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Logout -->
                <Border Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="&#x1F6AA; 退出登录" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="返回登录界面" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="退出"
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource SettingsButtonStyle}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Connection String Section -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="&#x1F5C4;&#xFE0F; 数据库连接字符串" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                    <TextBox Grid.Row="1"
                             Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             FontSize="12"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Padding="8,6"/>

                    <Button Grid.Row="2" Content="保存"
                            Command="{Binding SaveConnectionStringCommand}"

                            Margin="0,8,0,0"
                            HorizontalAlignment="Right">
                        <Button.Style>
                            <Style BasedOn="{StaticResource SettingsButtonStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="3" Margin="0,12,0,0" Padding="0,4,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
