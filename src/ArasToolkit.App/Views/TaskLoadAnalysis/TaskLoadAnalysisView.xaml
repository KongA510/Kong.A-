<UserControl x:Class="ArasToolkit.App.Views.TaskLoadAnalysis.TaskLoadAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: 标题 + 日期选择 -->
        <Border Grid.Row="0" Background="White" Padding="20,14" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📊" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="任务负载分析" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0" />
                </StackPanel>

                <!-- 右侧操作区 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="开始日期" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <DatePicker SelectedDate="{Binding StartDate}" Width="130" FontSize="13"
                                VerticalContentAlignment="Center" Margin="0,0,12,0" />
                    <TextBlock Text="结束日期" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <DatePicker SelectedDate="{Binding EndDate}" Width="130" FontSize="13"
                                VerticalContentAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="🚀 开始分析" Command="{Binding AnalyzeCommand}"
                            Padding="16,7" Background="#6366F1" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="13" FontWeight="SemiBold" />
                    <Button Content="⏹ 取消" Command="{Binding CancelCommand}"
                            Padding="14,7" Background="#EF4444" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="13" Margin="8,0,0,0"
                            Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：AI 流式分析输出 -->
            <Border Grid.Column="0" Background="#FAFAFA" Margin="16,16,8,16"
                    CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="16,10" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <TextBlock Text="分析报告" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <TextBlock Text="{Binding AnalysisContent}"
                                   FontSize="14" LineHeight="24"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"
                                   FontFamily="Microsoft YaHei UI" />
                    </ScrollViewer>

                    <TextBlock Grid.Row="1"
                               Text="选择日期范围后点击「开始分析」，AI 将逐步输出任务负载分析报告"
                               FontSize="14" Foreground="#9CA3AF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding AnalysisContent, Converter={StaticResource StringToVisibility}, ConverterParameter=Invert}" />
                </Grid>
            </Border>

            <!-- 右侧：历史记录 -->
            <Border Grid.Column="1" Background="White" Margin="8,16,16,16"
                    CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="14,10" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="📜 分析历史" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <Button Content="🔄" HorizontalAlignment="Right" FontSize="14"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Command="{Binding RefreshHistoryCommand}" ToolTip="刷新" />
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding HistoryRecords}"
                             SelectedItem="{Binding SelectedRecord}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="4,2" Background="#F9FAFB"
                                        CornerRadius="6" Cursor="Hand">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding DisplayDateRange}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="1" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                                   Text="{Binding Preview}" />
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="{Binding DisplayCreatedOn}" FontSize="11"
                                                       Foreground="#9CA3AF" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding TaskCount, StringFormat='任务数: {0}'}"
                                                       FontSize="11" Foreground="#6366F1"
                                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                                            <Button Content="🗑" FontSize="12" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"
                                                    Command="{Binding DataContext.DeleteRecordCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" ToolTip="删除" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2" Padding="10,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="‹" Command="{Binding PrevHistoryPageCommand}"
                                    Width="28" Height="28" Background="Transparent"
                                    BorderBrush="#D1D5DB" BorderThickness="1" Cursor="Hand" FontSize="12" />
                            <TextBlock Text="{Binding HistoryPage, StringFormat=' {0} '}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0" />
                            <Button Content="›" Command="{Binding NextHistoryPageCommand}"
                                    Width="28" Height="28" Background="Transparent"
                                    BorderBrush="#D1D5DB" BorderThickness="1" Cursor="Hand" FontSize="12" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 2: 底部状态栏 -->
        <Border Grid.Row="2" Background="White" Padding="20,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="分析规则: 每天标准工时 8 小时 | 超过 6 小时预警 | 超过 8 小时超载"
                       FontSize="12" Foreground="#9CA3AF" />
        </Border>
    </Grid>
</UserControl>
