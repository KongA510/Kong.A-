<UserControl x:Class="ArasToolkit.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28">

            <!-- 返回按钮 + 标题 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Button Content="← 返回"
                        Click="BackButton_Click"
                        Style="{DynamicResource FluentButton}"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Padding="12,6" Cursor="Hand" FontSize="12"
                        Margin="0,0,16,0" />
                <TextBlock x:Name="PageTitle" Text="设置"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- DataFolder Panel -->
            <Border x:Name="DataFolderPanel" Visibility="Collapsed"
                    Style="{DynamicResource SimpleCard}" Padding="24,20" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="📁 资料文件夹地址" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="设置个人资料文件的存储位置" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding DataFolderPath}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>
                        <Button Content="浏览文件夹"
                                Command="{Binding BrowseDataFolderCommand}"
                                Style="{DynamicResource AccentButton}"
                                Padding="16,8" Cursor="Hand" FontSize="13"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- AI Model Panel -->
            <Border x:Name="AiModelPanel" Visibility="Collapsed"
                    Style="{DynamicResource SimpleCard}" Padding="24,20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🤖 AI 模型配置" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="管理多个AI模型API Key，支持启用/切换" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="AI模型配置已迁移到独立页面，请通过设置菜单中的卡片进入" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Database Check Panel -->
            <Border x:Name="DatabasePanel" Visibility="Collapsed"
                    Style="{DynamicResource SimpleCard}" Padding="24,20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🔍 数据库检查" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="检查数据库表结构完整性，同步缺失字段" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>
                    <Button Content="执行检查"
                            Command="{Binding CheckDatabaseCommand}"
                            Padding="16,8" Cursor="Hand" FontSize="13"
                            HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCheckingDb}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,12,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Connection String Panel -->
            <Border x:Name="ConnectionPanel" Visibility="Collapsed"
                    Style="{DynamicResource SimpleCard}" Padding="24,20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🗄️ 数据库连接字符串" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="配置应用数据库连接，保存后即时生效" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>
                    <TextBox Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80"
                             FontSize="12" Padding="10,8"
                             Style="{DynamicResource FluentTextBox}"
                             Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="保存"
                                Command="{Binding SaveConnectionStringCommand}"
                                Padding="16,8" Cursor="Hand" FontSize="13"
                                HorizontalAlignment="Left">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="16,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Logout Panel -->
            <Border x:Name="LogoutPanel" Visibility="Collapsed"
                    Style="{DynamicResource SimpleCard}" Padding="24,20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🚪 退出登录" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="退出当前登录，返回登录界面" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,16"/>
                    <Button Content="确认退出"
                            Command="{Binding LogoutCommand}"
                            Padding="16,8" Cursor="Hand" FontSize="13"
                            HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C42B1C" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
