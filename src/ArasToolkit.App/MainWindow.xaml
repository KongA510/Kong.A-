<Window x:Class="ArasToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArasToolkit.App"
        xmlns:views="clr-namespace:ArasToolkit.App.Views"
        xmlns:placeholder="clr-namespace:ArasToolkit.App.Views.Placeholder"
        xmlns:converters="clr-namespace:ArasToolkit.App.Converters"
        xmlns:models="clr-namespace:ArasToolkit.Core.Models;assembly=ArasToolkit.Core"
        mc:Ignorable="d"
        Title="个人工具箱"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{DynamicResource SystemBaseBrush}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />

        <!-- ===== 导航菜单 HierarchicalDataTemplate ===== -->
        <HierarchicalDataTemplate DataType="{x:Type models:MenuItemInfo}"
                                  ItemsSource="{Binding Children}">
            <ContentPresenter Content="{Binding Name}" Visibility="Collapsed" />
        </HierarchicalDataTemplate>

        <!-- ===== Fluent 风格导航项样式 ===== -->
        <Style x:Key="FluentNavItemStyle" TargetType="TreeViewItem">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- 当前节点 -->
                            <Border x:Name="NavBorder"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    Padding="10,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧选中指示条 -->
                                    <Border x:Name="IndicatorBar"
                                            Grid.Column="0"
                                            Background="Transparent"
                                            CornerRadius="2" />

                                    <!-- 展开/折叠箭头 -->
                                    <ToggleButton x:Name="ExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibility}}"
                                                  Width="16" Height="16"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Cursor="Hand"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock x:Name="Arrow"
                                                           Text="▶"
                                                           FontSize="8"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="0" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Text" Value="▼" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <!-- 图标 -->
                                    <TextBlock x:Name="IconText"
                                               Grid.Column="2"
                                               Text="●"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />

                                    <!-- 菜单名 -->
                                    <TextBlock x:Name="NavLabel"
                                               Grid.Column="3"
                                               Text="{Binding Name}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </Grid>
                            </Border>

                            <!-- 子节点容器 -->
                            <ItemsPresenter x:Name="ChildrenHost" Margin="28,0,0,0" Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ChildrenHost" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <!-- Hover -->
                            <Trigger SourceName="NavBorder" Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                <Setter TargetName="IconText" Property="Foreground" Value="{DynamicResource SystemAccentBrush}" />
                                <Setter TargetName="NavLabel" Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <!-- Selected: 左侧指示条 + 半透明背景 + 强调色文字 -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                <Setter TargetName="IndicatorBar" Property="Background" Value="{DynamicResource SystemAccentBrush}" />
                                <Setter TargetName="IconText" Property="Foreground" Value="{DynamicResource SystemAccentBrush}" />
                                <Setter TargetName="NavLabel" Property="Foreground" Value="{DynamicResource SystemAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主布局 -->
    <Border Background="{DynamicResource SystemBaseBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== Fluent 风格标题栏 ===== -->
            <Grid Grid.Row="0" Background="{DynamicResource SystemFillColorNeutralBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo + 标题 -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Image Source="/app.ico" Width="16" Height="16" Margin="0,0,8,0" Stretch="UniformToFill" />
                    <TextBlock Text="个人工具箱" FontSize="13"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" FontWeight="SemiBold" />
                </StackPanel>

                <!-- 窗口控制按钮 -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="─" Click="MinimizeButton_Click"
                            Width="46" Height="32"
                            Background="Transparent" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand" FontSize="10" />
                    <Button Content="□" Click="MaximizeButton_Click"
                            Width="46" Height="32"
                            Background="Transparent" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand" FontSize="10" />
                    <Button x:Name="CloseButton" Content="✕" Click="CloseButton_Click"
                            Width="46" Height="32"
                            Background="Transparent" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand" FontSize="12">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C42B1C" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 主体布局: 左侧导航 + 右侧内容 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左侧导航栏（登录前隐藏） -->
                <Border Grid.Column="0" Background="{DynamicResource SystemListLowBrush}" Width="240"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Logo区域 -->
                        <StackPanel Grid.Row="0" Margin="20,20,20,16">
                            <TextBlock Text="个人工具箱" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="开发工具集" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- 导航菜单 -->
                        <TreeView Grid.Row="1"
                                  ItemsSource="{Binding MenuItems}"
                                  PreviewMouseLeftButtonDown="NavTree_PreviewMouseLeftButtonDown"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource FluentNavItemStyle}"
                                  Margin="4,0" />

                        <!-- 底部设置按钮 -->
                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="12,12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="⚙ 设置"
                                        Click="SettingsButton_Click"
                                        Style="{DynamicResource FluentButton}"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Padding="12,6"
                                        Cursor="Hand" FontSize="12" />
                                <Button Content="🔆 Aras信息"
                                        Click="ArasLoginButton_Click"
                                        Style="{DynamicResource FluentButton}"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Padding="8,6"
                                        Cursor="Hand" FontSize="12"
                                        Margin="6,0,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 分隔线 -->
                <Border Grid.Column="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Width="1"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}" />

                <!-- 右侧内容区域 -->
                <Border Grid.Column="2" Background="{DynamicResource SystemBaseBrush}">
                    <Grid>
                        <!-- 登录界面（覆盖层） -->
                        <ContentControl x:Name="LoginContentControl"
                                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />

                        <!-- 主内容区域 -->
                        <ContentControl x:Name="MainContentControl"
                                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="2" Background="{DynamicResource SystemFillColorNeutralBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                    Padding="16,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding VersionText}" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text=" | .NET 8.0" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="12,0,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
